<Window x:Class="MozaTelemetryPlugin.ColorPickerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Pick LED Color" Width="320" Height="280"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <StackPanel Margin="15">
        <!-- Preview -->
        <Border x:Name="ColorPreview" Height="50" CornerRadius="5" Margin="0,0,0,15"
                BorderBrush="#555" BorderThickness="1" Background="Black"/>

        <!-- R slider -->
        <StackPanel Orientation="Horizontal" Margin="0,4">
            <TextBlock Text="R" Width="20" VerticalAlignment="Center" Foreground="Red" FontWeight="Bold"/>
            <Slider x:Name="RSlider" Width="220" Minimum="0" Maximum="255" TickFrequency="1"
                    IsSnapToTickEnabled="True" ValueChanged="Slider_ValueChanged"/>
            <TextBlock x:Name="RValue" Width="35" TextAlignment="Right" VerticalAlignment="Center"
                       FontFamily="Consolas" Text="0"/>
        </StackPanel>

        <!-- G slider -->
        <StackPanel Orientation="Horizontal" Margin="0,4">
            <TextBlock Text="G" Width="20" VerticalAlignment="Center" Foreground="Green" FontWeight="Bold"/>
            <Slider x:Name="GSlider" Width="220" Minimum="0" Maximum="255" TickFrequency="1"
                    IsSnapToTickEnabled="True" ValueChanged="Slider_ValueChanged"/>
            <TextBlock x:Name="GValue" Width="35" TextAlignment="Right" VerticalAlignment="Center"
                       FontFamily="Consolas" Text="0"/>
        </StackPanel>

        <!-- B slider -->
        <StackPanel Orientation="Horizontal" Margin="0,4">
            <TextBlock Text="B" Width="20" VerticalAlignment="Center" Foreground="CornflowerBlue" FontWeight="Bold"/>
            <Slider x:Name="BSlider" Width="220" Minimum="0" Maximum="255" TickFrequency="1"
                    IsSnapToTickEnabled="True" ValueChanged="Slider_ValueChanged"/>
            <TextBlock x:Name="BValue" Width="35" TextAlignment="Right" VerticalAlignment="Center"
                       FontFamily="Consolas" Text="0"/>
        </StackPanel>

        <!-- Buttons -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="Off" Width="50" Margin="0,0,8,0" Click="Off_Click"/>
            <Button Content="Cancel" Width="60" Margin="0,0,8,0" Click="Cancel_Click"/>
            <Button Content="OK" Width="60" IsDefault="True" Click="Ok_Click"/>
        </StackPanel>
    </StackPanel>
</Window>
