                        </StackPanel>
                        <TextBlock Text="This will reset all plugin settings and profiles to their defaults."
                                   Foreground="Gray" FontSize="11" Margin="0,4,0,0"/>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Dashboard Telemetry">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="10,5">
                        <TextBlock Text="Dashboard Telemetry" Style="{StaticResource SectionHeader}"/>
                        <TextBlock TextWrapping="Wrap" Foreground="Gray"
                                   Text="Telemetry enable/disable and dashboard profile selection have moved to the MOZA Wheel device tab (Devices > your wheel > MOZA Wheel)."/>

                        <!-- Separator -->
                        <!-- Separator -->
                        <Separator Margin="0,4,0,8"/>
                        <TextBlock Text="Test Pattern" FontWeight="SemiBold" Margin="0,0,0,6"/>

                        <!-- Test pattern controls -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <Button x:Name="TelemetryTestStartBtn" Content="▶ Send Test Pattern"
                                    Padding="6,2" Margin="0,0,8,0" Click="TelemetryTestStart_Click"/>
                            <Button x:Name="TelemetryTestStopBtn" Content="■ Stop"
                                    Padding="6,2" Click="TelemetryTestStop_Click" IsEnabled="False"/>
                        </StackPanel>
                        <TextBlock Text="Cycles: Gear 1→6, Brake 0→100%, Speed 0→200 km/h" Foreground="Gray"
                                   FontSize="11" Margin="0,0,0,8"/>

                        <!-- Separator -->
                        <Separator Margin="0,4,0,8"/>
                        <TextBlock Text="Status" FontWeight="SemiBold" Margin="0,0,0,6"/>

                        <!-- Frame log -->
                        <Button Content="Export Frame Log…" Padding="6,2" Margin="0,0,0,8"
                                Click="TelemetryExportLog_Click"/>
                        <TextBlock Text="Last frame:" Margin="0,0,0,2"/>
                        <TextBlock x:Name="TelemetryLastFrameLabel"
                                   FontFamily="Consolas" FontSize="11" TextWrapping="Wrap"
                                   Foreground="Gray" Text="—" Margin="0,0,0,4"/>
                        <TextBlock x:Name="TelemetryStatusLabel" Foreground="Gray" FontSize="11"
                                   Text="Disabled" Margin="0,0,0,4"/>

                        <!-- Display sub-device info -->
                        <TextBlock x:Name="TelemetryDisplayLabel" Foreground="Gray" FontSize="11"
                                   Text="" Margin="0,0,0,4"/>
                        <TextBlock x:Name="TelemetryWheelChannelsLabel" Foreground="Gray" FontSize="11"
                                   TextWrapping="Wrap" Text="" Margin="0,0,0,8"/>

                        <!-- Advanced / debug -->
                        <Separator Margin="0,4,0,8"/>
                        <TextBlock Text="Advanced" FontWeight="SemiBold" Margin="0,0,0,6"/>
                        <CheckBox x:Name="UploadDashboardCheck" Content="Upload dashboard on connect"
                                  Margin="0,0,0,4" Checked="UploadDashboard_Changed" Unchecked="UploadDashboard_Changed"/>
                        <TextBlock TextWrapping="Wrap" Foreground="Gray" FontSize="11" Margin="0,0,0,8"
                                   Text="PitHouse uploads the dashboard file to the wheel on every connection. Disable to test telemetry without upload."/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <TextBlock Text="Protocol version:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <ComboBox x:Name="ProtocolVersionCombo" Width="320"
                                      SelectionChanged="ProtocolVersion_Changed">
                                <ComboBoxItem Content="0 — URL subscription (CSP-style)"/>
                                <ComboBoxItem Content="2 — Compact numeric (VGS-style)"/>
                                <ComboBoxItem Content="3 — Compact numeric, two-batch (PitHouse)"/>
                            </ComboBox>
                        </StackPanel>
                        <TextBlock TextWrapping="Wrap" Foreground="Gray" FontSize="11" Margin="0,2,0,8"
                                   Text="Tier definition format. Version 3 (default) matches PitHouse's probe-then-def sequence. 2 is single-batch compact numeric; 0 sends URLs for the wheel to resolve. Telemetry restarts automatically on change."/>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Diagnostics">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="10,5">
                        <TextBlock Text="Diagnostics" Style="{StaticResource SectionHeader}"/>
                        <TextBlock TextWrapping="Wrap" Foreground="Gray" FontSize="11" Margin="0,0,0,8"
                                   Text="Live dump of wheel identity, display sub-device identity, dashboard state from the wheel's configJson RPC, and session/connection info. Refreshes ~1/s."/>

                        <!-- Wheel identity -->
                        <TextBlock Text="Wheel identity" FontWeight="SemiBold" Margin="0,0,0,6"/>
                        <TextBlock x:Name="DiagWheelIdentityBox" FontFamily="Consolas" FontSize="11"
                                   TextWrapping="Wrap" Text="—" Margin="0,0,0,10"/>

                        <Separator Margin="0,4,0,8"/>

                        <!-- Display sub-device identity -->
                        <TextBlock Text="Display sub-device identity" FontWeight="SemiBold" Margin="0,0,0,6"/>
                        <TextBlock x:Name="DiagDisplayIdentityBox" FontFamily="Consolas" FontSize="11"
                                   TextWrapping="Wrap" Text="—" Margin="0,0,0,10"/>

                        <Separator Margin="0,4,0,8"/>

                        <!-- Dashboard state (session 0x09 configJson RPC) -->
                        <TextBlock Text="Wheel dashboard state (session 0x09)" FontWeight="SemiBold" Margin="0,0,0,6"/>
                        <TextBlock x:Name="DiagDashboardStateBox" FontFamily="Consolas" FontSize="11"
                                   TextWrapping="Wrap" Text="—" Margin="0,0,0,10"/>

                        <Separator Margin="0,4,0,8"/>

                        <!-- Tile-server state (session 0x03, if received) -->
                        <TextBlock Text="Tile-server state (session 0x03)" FontWeight="SemiBold" Margin="0,0,0,6"/>
                        <TextBlock x:Name="DiagTileServerBox" FontFamily="Consolas" FontSize="11"
                                   TextWrapping="Wrap" Text="—" Margin="0,0,0,10"/>

                        <Separator Margin="0,4,0,8"/>

                        <!-- Session / connection -->
                        <TextBlock Text="Session state" FontWeight="SemiBold" Margin="0,0,0,6"/>
                        <TextBlock x:Name="DiagSessionBox" FontFamily="Consolas" FontSize="11"
                                   TextWrapping="Wrap" Text="—" Margin="0,0,0,10"/>

                        <Button Content="Copy all to clipboard" Padding="6,2"
                                Click="DiagCopyAll_Click" HorizontalAlignment="Left" Margin="0,4,0,0"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

        </TabControl>
    </DockPanel>
</UserControl>
