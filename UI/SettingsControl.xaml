<UserControl x:Class="MozaPlugin.SettingsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:profilescommon="clr-namespace:SimHub.Plugins.ProfilesCommon;assembly=SimHub.Plugins"
             xmlns:ctrl="clr-namespace:MozaControls"
             Padding="0"
             Background="{DynamicResource BgPanelBrush}"
             TextElement.Foreground="{DynamicResource TextBrush}"
             TextElement.FontFamily="{DynamicResource FontUi}"
             TextElement.FontSize="13">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/MozaPlugin;component/Themes/MozaTheme.xaml"/>
                <ResourceDictionary Source="pack://application:,,,/MozaPlugin;component/Themes/MozaIcons.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- Legacy keys preserved so the hidden Wheel/AB9/mBooster/Hub tabs (kept in
                 the visual tree but Visibility=Collapsed in Phase 1) still resolve.
                 They route to the new design's brushes + typography so any pixels they
                 do emit blend in. Phase 2 deletes these along with the stub tabs. -->
            <Style x:Key="SectionHeader" TargetType="TextBlock" BasedOn="{StaticResource SectionTitleText}">
                <Setter Property="Margin" Value="0,20,0,8"/>
                <Setter Property="FontSize" Value="14"/>
            </Style>
            <Style x:Key="SliderLabel" TargetType="TextBlock" BasedOn="{StaticResource LabelText}">
                <Setter Property="Width" Value="180"/>
            </Style>
            <Style x:Key="SliderValue" TargetType="TextBlock">
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="Width" Value="60"/>
                <Setter Property="TextAlignment" Value="Right"/>
                <Setter Property="Margin" Value="8,0,0,0"/>
                <Setter Property="FontFamily" Value="{StaticResource FontMono}"/>
                <Setter Property="Foreground" Value="{StaticResource CyanBrush}"/>
            </Style>
            <Style x:Key="SettingSlider" TargetType="Slider" BasedOn="{StaticResource MozaSlider}">
                <Setter Property="Width" Value="300"/>
                <Setter Property="IsSnapToTickEnabled" Value="True"/>
            </Style>
            <Style x:Key="TempValue" TargetType="TextBlock">
                <Setter Property="FontFamily" Value="{StaticResource FontMono}"/>
                <Setter Property="FontSize" Value="18"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="Margin" Value="10,0,20,0"/>
                <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            </Style>
            <Style x:Key="ConnectionDot" TargetType="Ellipse">
                <Setter Property="Width" Value="12"/>
                <Setter Property="Height" Value="12"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="Margin" Value="0,0,8,0"/>
            </Style>
            <Style x:Key="ColorRect" TargetType="Border">
                <Setter Property="Width" Value="28"/>
                <Setter Property="Height" Value="28"/>
                <Setter Property="BorderBrush" Value="#555"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="CornerRadius" Value="3"/>
                <Setter Property="Margin" Value="2,0"/>
                <Setter Property="Cursor" Value="Hand"/>
            </Style>
            <Style x:Key="LedIndex" TargetType="TextBlock">
                <Setter Property="Width" Value="28"/>
                <Setter Property="TextAlignment" Value="Center"/>
                <Setter Property="Foreground" Value="{StaticResource TextFaintBrush}"/>
                <Setter Property="FontSize" Value="10"/>
                <Setter Property="Margin" Value="2,0"/>
            </Style>

            <!-- Default styles for native WPF controls used throughout (Buttons,
                 CheckBoxes, ComboBoxes get the new dark aesthetic automatically). -->
            <Style TargetType="Button" BasedOn="{StaticResource MozaButton}"/>
            <Style TargetType="CheckBox" BasedOn="{StaticResource MozaCheckBox}"/>
            <Style TargetType="ComboBox" BasedOn="{StaticResource MozaCombo}"/>
            <Style TargetType="Slider" BasedOn="{StaticResource MozaSlider}"/>
            <Style TargetType="TextBlock">
                <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            </Style>
            <Style TargetType="Separator">
                <Setter Property="Background" Value="{StaticResource BorderBrush}"/>
                <Setter Property="Height" Value="1"/>
            </Style>
            <Style TargetType="Expander">
                <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                <Setter Property="Background" Value="{StaticResource BgCardBrush}"/>
            </Style>
            <Style TargetType="ProgressBar">
                <Setter Property="Background" Value="{StaticResource BgTrackBrush}"/>
                <Setter Property="Foreground" Value="{StaticResource CyanBrush}"/>
                <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            </Style>
            <Style TargetType="DataGrid">
                <Setter Property="Background" Value="{StaticResource BgCardBrush}"/>
                <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource BorderBrush}"/>
                <Setter Property="VerticalGridLinesBrush" Value="{StaticResource BorderBrush}"/>
                <Setter Property="RowBackground" Value="{StaticResource BgCardBrush}"/>
                <Setter Property="AlternatingRowBackground" Value="{StaticResource BgCard2Brush}"/>
            </Style>

            <!-- Row-grid template used by every restyled slider row -->
            <Style x:Key="RowGrid" TargetType="Grid">
                <Setter Property="Margin" Value="0,4"/>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <DockPanel LastChildFill="True">
        <!-- ============ Top bar (brand + connection + profile) ============ -->
        <Border DockPanel.Dock="Top"
                Background="{StaticResource TopBarBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="22,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <!-- Brand block -->
                <Border Grid.Column="0"
                        BorderThickness="0,0,1,0" BorderBrush="{StaticResource BorderBrush}"
                        Padding="0,0,18,0" Margin="0,0,18,0">
                    <StackPanel Orientation="Horizontal">
                        <Rectangle Width="28" Height="28" Fill="{StaticResource CyanBrush}"
                                   RadiusX="3" RadiusY="3" Margin="0,0,10,0"/>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="UNOFFICIAL"
                                       FontSize="8" FontWeight="SemiBold"
                                       Foreground="{StaticResource AmberBrush}"
                                       Background="#22FFB84D"
                                       Padding="5,1"
                                       HorizontalAlignment="Left"/>
                            <TextBlock Text="MOZA" FontWeight="Bold" FontSize="13"
                                       Foreground="{StaticResource TextBrush}"/>
                            <TextBlock Text="SimHub Plugin" FontSize="9"
                                       Foreground="{StaticResource TextFaintBrush}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Connection pill + enable toggle -->
                <ctrl:ConnectionPill Grid.Column="1" x:Name="ConnectionPill"
                                     Margin="0,0,12,0"
                                     VerticalAlignment="Center"/>

                <!-- Legacy hidden controls kept for code-behind binding contracts.
                     ConnectionIndicator + ConnectionLabel are written by .cs; we
                     route those updates into ConnectionPill from code-behind. -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" Visibility="Collapsed">
                    <Ellipse x:Name="ConnectionIndicator" Style="{StaticResource ConnectionDot}" Fill="Gray"/>
                    <TextBlock x:Name="ConnectionLabel" Text="Disconnected"/>
                </StackPanel>

                <ctrl:OffOnToggle Grid.Column="2" x:Name="ConnectionToggle"
                                  Margin="0,0,12,0" IsChecked="True"
                                  Checked="ConnectionToggle_Changed"
                                  Unchecked="ConnectionToggle_Changed"
                                  VerticalAlignment="Center"/>

                <Button Grid.Column="3" x:Name="RefreshButton" Content="REFRESH"
                        Click="RefreshButton_Click" VerticalAlignment="Center"/>

                <!-- Profile selector (right-aligned via column 4 stretch) -->
                <profilescommon:ProfileList Grid.Column="4" x:Name="ProfileListControl"
                                            Margin="18,0,0,0"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Restart notice -->
        <Border x:Name="RestartBanner" DockPanel.Dock="Top" Visibility="Collapsed"
                Style="{StaticResource BannerBorder}" Margin="22,12,22,0">
            <TextBlock Text="New device definitions were deployed. Restart SimHub to add them under Devices."
                       Foreground="#FFD7A0" TextWrapping="Wrap"/>
        </Border>

        <!-- Tabs -->
        <TabControl Style="{StaticResource MozaTabControl}">

            <!-- ==================== BASE TAB ==================== -->
            <TabItem Header="Base">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="22,18,22,40">
                    <StackPanel>
                        <!-- Live telemetry header -->
                        <Border Background="{StaticResource BgCardBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1" CornerRadius="8"
                                Padding="18" Margin="0,0,0,14">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="240"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <ctrl:SteeringArc Grid.Column="0" x:Name="SteeringArcViz"
                                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="1" Margin="18,0,0,0">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                        <Ellipse Width="7" Height="7" Fill="{StaticResource GreenBrush}"
                                                 VerticalAlignment="Center" Margin="0,0,8,0"
                                                 Effect="{StaticResource GreenGlowEffect}"/>
                                        <TextBlock Text="LIVE" FontWeight="Bold" FontSize="10"
                                                   Foreground="{StaticResource GreenBrush}"
                                                   VerticalAlignment="Center" Margin="0,0,12,0"/>
                                        <TextBlock Text="Wheelbase telemetry" Style="{StaticResource MutedHintText}"
                                                   VerticalAlignment="Center" Margin="0,0,18,0"/>
                                        <Button x:Name="BaseCalibrateButton" Content="CALIBRATE CENTER"
                                                Click="BaseCalibrateButton_Click"
                                                VerticalAlignment="Center"/>
                                        <TextBlock x:Name="BaseCalibrateStatus"
                                                   Style="{StaticResource MutedHintText}"
                                                   Margin="10,0,0,0"/>
                                    </StackPanel>
                                    <UniformGrid Columns="3" Rows="1" Margin="0,0,0,4">
                                        <ctrl:TempCell x:Name="McuTempCell" Label="MCU"
                                                       Margin="0,0,8,0"
                                                       WarnThreshold="65" DangerThreshold="85"/>
                                        <ctrl:TempCell x:Name="MosfetTempCell" Label="MOSFET"
                                                       Margin="4,0"
                                                       WarnThreshold="70" DangerThreshold="90"/>
                                        <ctrl:TempCell x:Name="MotorTempCell" Label="MOTOR"
                                                       Margin="8,0,0,0"
                                                       WarnThreshold="80" DangerThreshold="100"/>
                                    </UniformGrid>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Legacy text-based readouts: hidden but kept so code-behind
                             that writes to SteeringAngleLabel.Text etc. still works.
                             .cs additionally pushes Angle into SteeringArcViz and
                             numeric values into the *TempCell controls. -->
                        <StackPanel Visibility="Collapsed">
                            <TextBlock x:Name="SteeringAngleLabel" Text="--"/>
                            <TextBlock x:Name="McuTempLabel" Text="--"/>
                            <TextBlock x:Name="MosfetTempLabel" Text="--"/>
                            <TextBlock x:Name="MotorTempLabel" Text="--"/>
                        </StackPanel>

                        <ctrl:SectionCard Title="CORE SETTINGS" Icon="{StaticResource IconBolt}">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,4">
                                    <TextBlock Text="Wheel Rotation Angle" Style="{StaticResource SliderLabel}"/>
                                    <Slider x:Name="RotationSlider" Style="{StaticResource SettingSlider}" Minimum="90" Maximum="2700" TickFrequency="10" SmallChange="10" LargeChange="10" IsSnapToTickEnabled="True" ValueChanged="RotationSlider_ValueChanged"/>
                                    <TextBlock x:Name="RotationValue" Style="{StaticResource SliderValue}" Text="900°"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,4">
                                    <TextBlock Text="Game FFB Strength" Style="{StaticResource SliderLabel}"/>
                                    <Slider x:Name="FfbStrengthSlider" Style="{StaticResource SettingSlider}" Minimum="0" Maximum="100" TickFrequency="1" ValueChanged="FfbStrengthSlider_ValueChanged"/>
                                    <TextBlock x:Name="FfbStrengthValue" Style="{StaticResource SliderValue}" Text="80%"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,4">
                                    <TextBlock Text="Base Torque Output" Style="{StaticResource SliderLabel}"/>
                                    <Slider x:Name="TorqueSlider" Style="{StaticResource SettingSlider}" Minimum="50" Maximum="100" TickFrequency="5" ValueChanged="TorqueSlider_ValueChanged"/>
                                    <TextBlock x:Name="TorqueValue" Style="{StaticResource SliderValue}" Text="100%"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,4">
                                    <TextBlock Text="Maximum Wheel Speed" Style="{StaticResource SliderLabel}"/>
                                    <Slider x:Name="SpeedSlider" Style="{StaticResource SettingSlider}" Minimum="0" Maximum="200" TickFrequency="1" ValueChanged="SpeedSlider_ValueChanged"/>
                                    <TextBlock x:Name="SpeedValue" Style="{StaticResource SliderValue}" Text="100%"/>
                                </StackPanel>
                            </StackPanel>
                        </ctrl:SectionCard>

                        <ctrl:SectionCard Title="WHEELBASE EFFECTS" Icon="{StaticResource IconDamper}">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,4">
                                    <TextBlock Text="Wheel Damper" Style="{StaticResource SliderLabel}"/>
                                    <Slider x:Name="DamperSlider" Style="{StaticResource SettingSlider}" Minimum="0" Maximum="100" TickFrequency="1" ValueChanged="DamperSlider_ValueChanged"/>
                                    <TextBlock x:Name="DamperValue" Style="{StaticResource SliderValue}" Text="0%"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,4">
                                    <TextBlock Text="Wheel Friction" Style="{StaticResource SliderLabel}"/>
                                    <Slider x:Name="FrictionSlider" Style="{StaticResource SettingSlider}" Minimum="0" Maximum="100" TickFrequency="1" ValueChanged="FrictionSlider_ValueChanged"/>
                                    <TextBlock x:Name="FrictionValue" Style="{StaticResource SliderValue}" Text="0%"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,4">
                                    <TextBlock Text="Natural Inertia" Style="{StaticResource SliderLabel}"/>
                                    <Slider x:Name="InertiaSlider" Style="{StaticResource SettingSlider}" Minimum="100" Maximum="500" TickFrequency="50" ValueChanged="InertiaSlider_ValueChanged"/>
                                    <TextBlock x:Name="InertiaValue" Style="{StaticResource SliderValue}" Text="250"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,4">
                                    <TextBlock Text="Wheel Spring" Style="{StaticResource SliderLabel}"/>
                                    <Slider x:Name="SpringSlider" Style="{StaticResource SettingSlider}" Minimum="0" Maximum="100" TickFrequency="1" ValueChanged="SpringSlider_ValueChanged"/>
                                    <TextBlock x:Name="SpringValue" Style="{StaticResource SliderValue}" Text="0%"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,8">
                                    <TextBlock Text="Force Feedback Reversal" Style="{StaticResource SliderLabel}"/>
                                    <ctrl:OffOnToggle x:Name="FfbReverseCheck" VerticalAlignment="Center" Click="FfbReverseCheck_Click"/>
                                </StackPanel>
                            </StackPanel>
                        </ctrl:SectionCard>

                        <ctrl:SectionCard Title="GAME EFFECTS" Icon="{StaticResource IconGame}">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,4">
                                    <TextBlock Text="Game Damper" Style="{StaticResource SliderLabel}"/>
                                    <Slider x:Name="GameDamperSlider" Style="{StaticResource SettingSlider}" Minimum="0" Maximum="100" TickFrequency="5" ValueChanged="GameDamperSlider_ValueChanged"/>
                                    <TextBlock x:Name="GameDamperValue" Style="{StaticResource SliderValue}" Text="50%"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,4">
                                    <TextBlock Text="Game Friction" Style="{StaticResource SliderLabel}"/>
                                    <Slider x:Name="GameFrictionSlider" Style="{StaticResource SettingSlider}" Minimum="0" Maximum="100" TickFrequency="5" ValueChanged="GameFrictionSlider_ValueChanged"/>
                                    <TextBlock x:Name="GameFrictionValue" Style="{StaticResource SliderValue}" Text="50%"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,4">
                                    <TextBlock Text="Game Inertia" Style="{StaticResource SliderLabel}"/>
                                    <Slider x:Name="GameInertiaSlider" Style="{StaticResource SettingSlider}" Minimum="0" Maximum="100" TickFrequency="5" ValueChanged="GameInertiaSlider_ValueChanged"/>
                                    <TextBlock x:Name="GameInertiaValue" Style="{StaticResource SliderValue}" Text="50%"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,4">
                                    <TextBlock Text="Game Spring" Style="{StaticResource SliderLabel}"/>
                                    <Slider x:Name="GameSpringSlider" Style="{StaticResource SettingSlider}" Minimum="0" Maximum="100" TickFrequency="5" ValueChanged="GameSpringSlider_ValueChanged"/>
                                    <TextBlock x:Name="GameSpringValue" Style="{StaticResource SliderValue}" Text="100%"/>
                                </StackPanel>
                            </StackPanel>
                        </ctrl:SectionCard>

                        <ctrl:SectionCard Title="HIGH SPEED DAMPING"
                                          Subtitle="// I have no idea what these settings do"
                                          Icon="{StaticResource IconSpeed}">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,4">
                                    <TextBlock Text="Damping Level" Style="{StaticResource SliderLabel}"/>
                                    <Slider x:Name="SpeedDampingSlider" Style="{StaticResource SettingSlider}" Minimum="0" Maximum="100" TickFrequency="1" ValueChanged="SpeedDampingSlider_ValueChanged"/>
                                    <TextBlock x:Name="SpeedDampingValue" Style="{StaticResource SliderValue}" Text="0%"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,4">
                                    <TextBlock Text="Trigger Speed" Style="{StaticResource SliderLabel}"/>
                                    <Slider x:Name="SpeedDampingPointSlider" Style="{StaticResource SettingSlider}" Minimum="0" Maximum="400" TickFrequency="10" ValueChanged="SpeedDampingPointSlider_ValueChanged"/>
                                    <TextBlock x:Name="SpeedDampingPointValue" Style="{StaticResource SliderValue}" Text="120 kph"/>
                                </StackPanel>
                            </StackPanel>
                        </ctrl:SectionCard>

                        <ctrl:SectionCard Title="PERFORMANCE" Icon="{StaticResource IconMisc}">
                            <StackPanel Orientation="Horizontal" Margin="0,4">
                                <TextBlock Text="Performance Output" Style="{StaticResource SliderLabel}"/>
                                <ctrl:SegmentedControl x:Name="PerformanceOutputCombo" SelectionChanged="PerformanceOutputCombo_Changed">
                                    <ListBoxItem Content="Reserved"/>
                                    <ListBoxItem Content="Full"/>
                                </ctrl:SegmentedControl>
                            </StackPanel>
                        </ctrl:SectionCard>

                        <ctrl:SectionCard Title="GEARSHIFT VIBRATION" Icon="{StaticResource IconShift}">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,4">
                                    <TextBlock Text="Shift Intensity" Style="{StaticResource SliderLabel}"/>
                                    <Slider x:Name="GearshiftVibrationSlider" Style="{StaticResource SettingSlider}" Minimum="0" Maximum="5" TickFrequency="1" SmallChange="1" LargeChange="1" IsSnapToTickEnabled="True" ValueChanged="GearshiftVibrationSlider_ValueChanged"/>
                                    <TextBlock x:Name="GearshiftVibrationValue" Style="{StaticResource SliderValue}" Text="0"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,4">
                                    <TextBlock Text="Vibrate on Neutral" Style="{StaticResource SliderLabel}"/>
                                    <ctrl:OffOnToggle x:Name="GearshiftVibrateOnNeutralCheck" VerticalAlignment="Center"
                                              Checked="GearshiftVibrateOnNeutralCheck_Changed" Unchecked="GearshiftVibrateOnNeutralCheck_Changed"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,4">
                                    <TextBlock Text="Shift Debounce" Style="{StaticResource SliderLabel}"/>
                                    <Slider x:Name="GearshiftDebounceSlider" Style="{StaticResource SettingSlider}" Minimum="0" Maximum="1000" TickFrequency="50" SmallChange="50" LargeChange="50" IsSnapToTickEnabled="True" ValueChanged="GearshiftDebounceSlider_ValueChanged"/>
                                    <TextBlock x:Name="GearshiftDebounceValue" Style="{StaticResource SliderValue}" Text="500 ms"/>
                                </StackPanel>
                            </StackPanel>
                        </ctrl:SectionCard>

                        <ctrl:SectionCard Title="PROTECTION" Icon="{StaticResource IconShield}">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,8">
                                    <TextBlock Text="Hands-Off Protection" Style="{StaticResource SliderLabel}"/>
                                    <ctrl:OffOnToggle x:Name="ProtectionCheck" VerticalAlignment="Center" Click="ProtectionCheck_Click"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,4">
                                    <TextBlock Text="Steering Wheel Inertia" Style="{StaticResource SliderLabel}"/>
                                    <Slider x:Name="NaturalInertiaSlider" Style="{StaticResource SettingSlider}" Minimum="100" Maximum="4000" TickFrequency="50" ValueChanged="NaturalInertiaSlider_ValueChanged"/>
                                    <TextBlock x:Name="NaturalInertiaValue" Style="{StaticResource SliderValue}" Text="1100"/>
                                </StackPanel>
                            </StackPanel>
                        </ctrl:SectionCard>

                        <ctrl:SectionCard Title="SOFT LIMIT" Icon="{StaticResource IconLimit}">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,4">
                                    <TextBlock Text="Stiffness" Style="{StaticResource SliderLabel}"/>
                                    <Slider x:Name="SoftLimitStiffnessSlider" Style="{StaticResource SettingSlider}" Minimum="1" Maximum="10" TickFrequency="1" ValueChanged="SoftLimitStiffnessSlider_ValueChanged"/>
                                    <TextBlock x:Name="SoftLimitStiffnessValue" Style="{StaticResource SliderValue}" Text="5"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,8">
                                    <TextBlock Text="Retain Game FFB" Style="{StaticResource SliderLabel}"/>
                                    <ctrl:OffOnToggle x:Name="SoftLimitRetainCheck" VerticalAlignment="Center" Click="SoftLimitRetainCheck_Click"/>
                                </StackPanel>
                            </StackPanel>
                        </ctrl:SectionCard>

                        <!-- FFB Equalizer (replaces 6 horizontal sliders below) -->
                        <ctrl:SectionCard Title="FFB EQUALIZER"
                                          Subtitle="// per-band gain · 100% = neutral · 400% = max boost"
                                          Icon="{StaticResource IconEq}">
                            <ctrl:MozaEqualizer x:Name="FfbEqualizer" Height="200"
                                                FrequencyLabels="10Hz,15Hz,25Hz,40Hz,60Hz,100Hz"
                                                MaxValue="400"/>
                        </ctrl:SectionCard>

                        <!-- Data-store sliders, driven by FfbEqualizer (visibility collapsed
                             so they don't render but their x:Name + ValueChanged still resolve). -->
                        <StackPanel Visibility="Collapsed">
                            <Slider x:Name="Eq1Slider" Minimum="0" Maximum="400" TickFrequency="1" ValueChanged="Eq1Slider_ValueChanged"/>
                            <TextBlock x:Name="Eq1Value" Text="100%"/>
                            <Slider x:Name="Eq2Slider" Minimum="0" Maximum="400" TickFrequency="1" ValueChanged="Eq2Slider_ValueChanged"/>
                            <TextBlock x:Name="Eq2Value" Text="100%"/>
                            <Slider x:Name="Eq3Slider" Minimum="0" Maximum="400" TickFrequency="1" ValueChanged="Eq3Slider_ValueChanged"/>
                            <TextBlock x:Name="Eq3Value" Text="100%"/>
                            <Slider x:Name="Eq4Slider" Minimum="0" Maximum="400" TickFrequency="1" ValueChanged="Eq4Slider_ValueChanged"/>
                            <TextBlock x:Name="Eq4Value" Text="100%"/>
                            <Slider x:Name="Eq5Slider" Minimum="0" Maximum="400" TickFrequency="1" ValueChanged="Eq5Slider_ValueChanged"/>
                            <TextBlock x:Name="Eq5Value" Text="100%"/>
                            <Slider x:Name="Eq6Slider" Minimum="0" Maximum="400" TickFrequency="1" ValueChanged="Eq6Slider_ValueChanged"/>
                            <TextBlock x:Name="Eq6Value" Text="100%"/>
                        </StackPanel>

                        <!-- FFB Output Curve (replaces 5 horizontal Y sliders below) -->
                        <ctrl:SectionCard Title="FFB OUTPUT CURVE"
                                          Subtitle="// drag the 5 nodes to shape response"
                                          Icon="{StaticResource IconCurve}">
                            <StackPanel>
                                <ctrl:MozaCurveEditor x:Name="FfbCurveEditor" Height="280"/>
                                <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                    <Button Content="LINEAR" Margin="0,0,8,0" Click="FfbCurvePreset_Linear"/>
                                    <Button Content="S CURVE" Margin="0,0,8,0" Click="FfbCurvePreset_SCurve"/>
                                    <Button Content="EXPONENTIAL" Margin="0,0,8,0" Click="FfbCurvePreset_Exponential"/>
                                    <Button Content="PARABOLIC" Click="FfbCurvePreset_Parabolic"/>
                                </StackPanel>
                            </StackPanel>
                        </ctrl:SectionCard>

                        <!-- Data-store sliders, driven by FfbCurveEditor -->
                        <StackPanel Visibility="Collapsed">
                            <Slider x:Name="FfbCurveY1Slider" Minimum="0" Maximum="100" TickFrequency="1" ValueChanged="FfbCurveY1Slider_ValueChanged"/>
                            <TextBlock x:Name="FfbCurveY1Value" Text="20"/>
                            <Slider x:Name="FfbCurveY2Slider" Minimum="0" Maximum="100" TickFrequency="1" ValueChanged="FfbCurveY2Slider_ValueChanged"/>
                            <TextBlock x:Name="FfbCurveY2Value" Text="40"/>
                            <Slider x:Name="FfbCurveY3Slider" Minimum="0" Maximum="100" TickFrequency="1" ValueChanged="FfbCurveY3Slider_ValueChanged"/>
                            <TextBlock x:Name="FfbCurveY3Value" Text="60"/>
                            <Slider x:Name="FfbCurveY4Slider" Minimum="0" Maximum="100" TickFrequency="1" ValueChanged="FfbCurveY4Slider_ValueChanged"/>
                            <TextBlock x:Name="FfbCurveY4Value" Text="80"/>
                            <Slider x:Name="FfbCurveY5Slider" Minimum="0" Maximum="100" TickFrequency="1" ValueChanged="FfbCurveY5Slider_ValueChanged"/>
                            <TextBlock x:Name="FfbCurveY5Value" Text="100"/>
                        </StackPanel>

                        <ctrl:SectionCard Title="MISCELLANEOUS" Icon="{StaticResource IconMisc}">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,8">
                                    <TextBlock Text="Standby Mode" Style="{StaticResource SliderLabel}"/>
                                    <ctrl:OffOnToggle x:Name="StandbyCheck" VerticalAlignment="Center" Click="StandbyCheck_Click"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,8">
                                    <TextBlock Text="Base Status LED" Style="{StaticResource SliderLabel}"/>
                                    <ctrl:OffOnToggle x:Name="LedStatusCheck" VerticalAlignment="Center" Click="LedStatusCheck_Click"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,8">
                                    <TextBlock Text="Bluetooth" Style="{StaticResource SliderLabel}"/>
                                    <ctrl:OffOnToggle x:Name="BluetoothCheck" VerticalAlignment="Center" Click="BluetoothCheck_Click"/>
                                </StackPanel>
                            </StackPanel>
                        </ctrl:SectionCard>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ==================== WHEEL TAB (Phase 6: hidden) ====================
                 Wheel-input settings + live paddle/button display now live in the
                 per-device MozaWheelSettingsControl "Inputs" sub-tab. The controls
                 here stay in the visual tree (Visibility=Collapsed) so the device
                 pane can forward user input to them, triggering this code-behind's
                 existing handler + persistence logic. -->
            <TabItem x:Name="WheelTab" Header="Wheel" Visibility="Collapsed">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="10">
                    <StackPanel Margin="5">

                        <!-- Live Input -->
                        <TextBlock Text="Paddles" Style="{StaticResource SectionHeader}"/>
                        <StackPanel x:Name="SplitPaddlePanel" Orientation="Horizontal" Margin="0,0,0,10">
                            <StackPanel Margin="0,0,20,0" Width="100">
                                <TextBlock Text="Left Paddle" Foreground="Gray" FontSize="11"/>
                                <ProgressBar x:Name="LeftPaddleBar" Height="14" Minimum="0" Maximum="100" Value="0"/>
                            </StackPanel>
                            <StackPanel Width="100">
                                <TextBlock Text="Right Paddle" Foreground="Gray" FontSize="11"/>
                                <ProgressBar x:Name="RightPaddleBar" Height="14" Minimum="0" Maximum="100" Value="0"/>
                            </StackPanel>
                        </StackPanel>
                        <StackPanel x:Name="CombinedPaddlePanel" Orientation="Horizontal" Margin="0,0,0,10" Visibility="Collapsed">
                            <StackPanel Width="100">
                                <TextBlock Text="Combined" Foreground="Gray" FontSize="11"/>
                                <ProgressBar x:Name="CombinedPaddleBar" Height="14" Minimum="0" Maximum="100" Value="0"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Active Buttons -->
                        <TextBlock Text="Buttons" Style="{StaticResource SectionHeader}" Margin="0,4,0,8"/>
                        <TextBlock x:Name="ActiveButtonsText" FontFamily="Consolas" FontSize="12"
                                   Foreground="Gray" Margin="0,0,0,10" TextWrapping="Wrap">None</TextBlock>

                        <!-- Paddle Settings -->
                        <TextBlock Text="Paddle Settings" Style="{StaticResource SectionHeader}"/>
                        <StackPanel Orientation="Horizontal" Margin="0,4">
                            <TextBlock Text="Paddles Mode" Style="{StaticResource SliderLabel}"/>
                            <ComboBox x:Name="WheelPaddlesModeCombo" Width="140" SelectionChanged="WheelPaddlesModeCombo_Changed">
                                <ComboBoxItem Content="Buttons"/>
                                <ComboBoxItem Content="Combined"/>
                                <ComboBoxItem Content="Split"/>
                            </ComboBox>
                        </StackPanel>
                        <StackPanel x:Name="WheelClutchPointPanel" Orientation="Horizontal" Margin="0,4" Visibility="Collapsed">
                            <TextBlock Text="Clutch Split Point" Style="{StaticResource SliderLabel}"/>
                            <Slider x:Name="WheelClutchPointSlider" Style="{StaticResource SettingSlider}" Minimum="0" Maximum="100" TickFrequency="1" ValueChanged="WheelClutchPointSlider_ValueChanged"/>
                            <TextBlock x:Name="WheelClutchPointValue" Style="{StaticResource SliderValue}" Text="50%"/>
                        </StackPanel>

                        <!-- Input Settings (knob + stick) -->
                        <TextBlock Text="Input Settings" Style="{StaticResource SectionHeader}"/>
                        <StackPanel x:Name="KnobModeLegacyPanel" Orientation="Horizontal" Margin="0,4">
                            <TextBlock Text="Rotary Encoders" Style="{StaticResource SliderLabel}"/>
                            <ComboBox x:Name="KnobModeCombo" Width="140" SelectionChanged="KnobModeCombo_Changed">
                                <ComboBoxItem Content="Buttons"/>
                                <ComboBoxItem Content="Knob"/>
                            </ComboBox>
                        </StackPanel>
                        <StackPanel x:Name="KnobSignalModePanel" Visibility="Collapsed">
                            <StackPanel x:Name="KnobSignalMode0Row" Orientation="Horizontal" Margin="0,4">
                                <TextBlock Text="Rotary 1" Style="{StaticResource SliderLabel}"/>
                                <ComboBox x:Name="KnobSignalMode0Combo" Width="140" SelectionChanged="KnobSignalMode0Combo_Changed">
                                    <ComboBoxItem Content="Buttons"/><ComboBoxItem Content="Knob"/>
                                </ComboBox>
                            </StackPanel>
                            <StackPanel x:Name="KnobSignalMode1Row" Orientation="Horizontal" Margin="0,4">
                                <TextBlock Text="Rotary 2" Style="{StaticResource SliderLabel}"/>
                                <ComboBox x:Name="KnobSignalMode1Combo" Width="140" SelectionChanged="KnobSignalMode1Combo_Changed">
                                    <ComboBoxItem Content="Buttons"/><ComboBoxItem Content="Knob"/>
                                </ComboBox>
                            </StackPanel>
                            <StackPanel x:Name="KnobSignalMode2Row" Orientation="Horizontal" Margin="0,4">
                                <TextBlock Text="Rotary 3" Style="{StaticResource SliderLabel}"/>
                                <ComboBox x:Name="KnobSignalMode2Combo" Width="140" SelectionChanged="KnobSignalMode2Combo_Changed">
                                    <ComboBoxItem Content="Buttons"/><ComboBoxItem Content="Knob"/>
                                </ComboBox>
                            </StackPanel>
                            <StackPanel x:Name="KnobSignalMode3Row" Orientation="Horizontal" Margin="0,4">
                                <TextBlock Text="Rotary 4" Style="{StaticResource SliderLabel}"/>
                                <ComboBox x:Name="KnobSignalMode3Combo" Width="140" SelectionChanged="KnobSignalMode3Combo_Changed">
                                    <ComboBoxItem Content="Buttons"/><ComboBoxItem Content="Knob"/>
                                </ComboBox>
                            </StackPanel>
                            <StackPanel x:Name="KnobSignalMode4Row" Orientation="Horizontal" Margin="0,4">
                                <TextBlock Text="Rotary 5" Style="{StaticResource SliderLabel}"/>
                                <ComboBox x:Name="KnobSignalMode4Combo" Width="140" SelectionChanged="KnobSignalMode4Combo_Changed">
                                    <ComboBoxItem Content="Buttons"/><ComboBoxItem Content="Knob"/>
                                </ComboBox>
                            </StackPanel>
                        </StackPanel>
                        <StackPanel x:Name="StickModeOldPanel" Orientation="Horizontal" Margin="0,8" Visibility="Collapsed">
                            <TextBlock Text="Stick as D-Pad" Style="{StaticResource SliderLabel}"/>
                            <ctrl:OffOnToggle x:Name="StickModeCheck" VerticalAlignment="Center" Click="StickModeCheck_Click"/>
                        </StackPanel>
                        <StackPanel x:Name="StickModeNewPanel" Orientation="Horizontal" Margin="0,8" Visibility="Collapsed">
                            <TextBlock Text="Joystick Assignment" Style="{StaticResource SliderLabel}"/>
                            <ComboBox x:Name="StickModeCombo" Width="120" SelectionChanged="StickModeCombo_Changed">
                                <ComboBoxItem Content="None"/>
                                <ComboBoxItem Content="Left"/>
                                <ComboBoxItem Content="Right"/>
                            </ComboBox>
                        </StackPanel>

                        <TextBlock TextWrapping="Wrap" Foreground="Gray" FontSize="11" Margin="0,12,0,0"
                                   Text="LED and button settings are in the MOZA Wheel device tab under Devices."/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ==================== HANDBRAKE TAB ==================== -->
            <TabItem x:Name="HandbrakeTab" Header="Handbrake" Visibility="Collapsed">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="10">
                    <StackPanel Margin="5">

                        <!-- Live Input -->
                        <TextBlock Text="Handbrake" Style="{StaticResource SectionHeader}"/>
                        <StackPanel x:Name="HandbrakeAxisPanel" Margin="0,0,0,10">
                            <StackPanel Width="100" HorizontalAlignment="Left">
                                <TextBlock Text="Position" Foreground="Gray" FontSize="11"/>
                                <ProgressBar x:Name="HandbrakeBar" Height="14" Minimum="0" Maximum="100" Value="0"/>
                            </StackPanel>
                        </StackPanel>
                        <TextBlock x:Name="HandbrakeButtonStatus" FontFamily="Consolas" FontSize="14"
                                   FontWeight="Normal" Margin="0,0,0,10" Visibility="Collapsed">Released</TextBlock>

                        <ctrl:SectionCard Title="HANDBRAKE SETTINGS" Icon="{StaticResource IconHandbrake}">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,4">
                                    <TextBlock Text="Mode" Style="{StaticResource SliderLabel}"/>
                                    <ctrl:SegmentedControl x:Name="HandbrakeModeCombo" SelectionChanged="HandbrakeModeCombo_Changed">
                                        <ListBoxItem Content="Axis"/>
                                        <ListBoxItem Content="Button"/>
                                    </ctrl:SegmentedControl>
                                </StackPanel>
                                <StackPanel x:Name="HandbrakeThresholdPanel" Orientation="Horizontal" Margin="0,4">
                                    <TextBlock Text="Button Threshold" Style="{StaticResource SliderLabel}"/>
                                    <Slider x:Name="HandbrakeThresholdSlider" Style="{StaticResource SettingSlider}" Minimum="0" Maximum="100" TickFrequency="1" ValueChanged="HandbrakeThresholdSlider_ValueChanged"/>
                                    <TextBlock x:Name="HandbrakeThresholdValue" Style="{StaticResource SliderValue}" Text="50%"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,8">
                                    <TextBlock Text="Reverse Direction" Style="{StaticResource SliderLabel}"/>
                                    <ctrl:OffOnToggle x:Name="HandbrakeDirectionCheck" VerticalAlignment="Center" Click="HandbrakeDirectionCheck_Click"/>
                                </StackPanel>
                            </StackPanel>
                        </ctrl:SectionCard>

                        <ctrl:SectionCard Title="RANGE" Icon="{StaticResource IconRange}">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,4">
                                    <TextBlock Text="Min" Style="{StaticResource SliderLabel}"/>
                                    <Slider x:Name="HandbrakeMinSlider" Style="{StaticResource SettingSlider}" Minimum="0" Maximum="100" TickFrequency="1" ValueChanged="HandbrakeMinSlider_ValueChanged"/>
                                    <TextBlock x:Name="HandbrakeMinValue" Style="{StaticResource SliderValue}" Text="0%"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,4">
                                    <TextBlock Text="Max" Style="{StaticResource SliderLabel}"/>
                                    <Slider x:Name="HandbrakeMaxSlider" Style="{StaticResource SettingSlider}" Minimum="0" Maximum="100" TickFrequency="1" ValueChanged="HandbrakeMaxSlider_ValueChanged"/>
                                    <TextBlock x:Name="HandbrakeMaxValue" Style="{StaticResource SliderValue}" Text="100%"/>
                                </StackPanel>
                            </StackPanel>
                        </ctrl:SectionCard>

                        <!-- Output Curve — drag-node editor replaces 5 horizontal Y sliders -->
                        <ctrl:SectionCard Title="OUTPUT CURVE"
                                          Subtitle="// map physical pull to game input"
                                          Icon="{StaticResource IconCurve}"
                                          AccentBrush="{StaticResource GreenBrush}">
                            <StackPanel>
                                <ctrl:MozaCurveEditor x:Name="HandbrakeCurveEditor" Height="260"
                                                      AccentBrush="{StaticResource GreenBrush}"/>
                                <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                    <Button Content="LINEAR" Margin="0,0,8,0" Click="HbCurvePreset_Linear"/>
                                    <Button Content="S CURVE" Margin="0,0,8,0" Click="HbCurvePreset_SCurve"/>
                                    <Button Content="EXPONENTIAL" Margin="0,0,8,0" Click="HbCurvePreset_Exponential"/>
                                    <Button Content="PARABOLIC" Click="HbCurvePreset_Parabolic"/>
                                </StackPanel>
                            </StackPanel>
                        </ctrl:SectionCard>

                        <!-- Data-store sliders, driven by HandbrakeCurveEditor -->
                        <StackPanel Visibility="Collapsed">
                            <Slider x:Name="HbY1Slider" Minimum="0" Maximum="100" TickFrequency="1" ValueChanged="HbY1Slider_ValueChanged"/>
                            <TextBlock x:Name="HbY1Value" Text="20"/>
                            <Slider x:Name="HbY2Slider" Minimum="0" Maximum="100" TickFrequency="1" ValueChanged="HbY2Slider_ValueChanged"/>
                            <TextBlock x:Name="HbY2Value" Text="40"/>
                            <Slider x:Name="HbY3Slider" Minimum="0" Maximum="100" TickFrequency="1" ValueChanged="HbY3Slider_ValueChanged"/>
                            <TextBlock x:Name="HbY3Value" Text="60"/>
                            <Slider x:Name="HbY4Slider" Minimum="0" Maximum="100" TickFrequency="1" ValueChanged="HbY4Slider_ValueChanged"/>
                            <TextBlock x:Name="HbY4Value" Text="80"/>
                            <Slider x:Name="HbY5Slider" Minimum="0" Maximum="100" TickFrequency="1" ValueChanged="HbY5Slider_ValueChanged"/>
                            <TextBlock x:Name="HbY5Value" Text="100"/>
                        </StackPanel>

                        <ctrl:SectionCard Title="CALIBRATION"
                                          Subtitle="// pull the handbrake fully once"
                                          Icon="{StaticResource IconCal}">
                            <StackPanel Orientation="Horizontal" Margin="0,4">
                                <Button x:Name="HbCalStartButton" Content="START CALIBRATION" Margin="0,0,10,0" Click="HbCalStartButton_Click"/>
                                <Button x:Name="HbCalStopButton" Content="STOP" Click="HbCalStopButton_Click"/>
                                <TextBlock x:Name="HbCalStatus" Style="{StaticResource MutedHintText}" Margin="14,0,0,0"/>
                            </StackPanel>
                        </ctrl:SectionCard>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ==================== PEDALS TAB ==================== -->
            <TabItem x:Name="PedalsTab" Header="Pedals" Visibility="Collapsed">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="22,18,22,40">
                    <StackPanel>

                        <!-- Live Input (3 colored bars stacked horizontally) -->
                        <Border Background="{StaticResource BgCardBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1" CornerRadius="8"
                                Padding="18,14" Margin="0,0,0,14">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                    <TextBlock Text="THROTTLE" Style="{StaticResource MutedHintText}" Margin="0,0,0,4"/>
                                    <ProgressBar x:Name="ThrottleBar" Height="14" Minimum="0" Maximum="100" Value="0"
                                                 Foreground="{StaticResource GreenBrush}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="4,0">
                                    <TextBlock Text="BRAKE" Style="{StaticResource MutedHintText}" Margin="0,0,0,4"/>
                                    <ProgressBar x:Name="BrakeBar" Height="14" Minimum="0" Maximum="100" Value="0"
                                                 Foreground="{StaticResource RedBrush}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2" Margin="8,0,0,0">
                                    <TextBlock Text="CLUTCH" Style="{StaticResource MutedHintText}" Margin="0,0,0,4"/>
                                    <ProgressBar x:Name="ClutchBar" Height="14" Minimum="0" Maximum="100" Value="0"
                                                 Foreground="{StaticResource CyanBrush}"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Pedal sub-selector chips -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                            <Button x:Name="PedalSelectorThrottle" Content="THROTTLE"
                                    Style="{StaticResource MozaButtonPrimary}"
                                    Margin="0,0,8,0" Padding="22,8"
                                    Click="PedalSelector_Throttle_Click"
                                    Tag="green"/>
                            <Button x:Name="PedalSelectorBrake" Content="BRAKE"
                                    Margin="0,0,8,0" Padding="22,8"
                                    Click="PedalSelector_Brake_Click"
                                    Tag="red"/>
                            <Button x:Name="PedalSelectorClutch" Content="CLUTCH"
                                    Padding="22,8"
                                    Click="PedalSelector_Clutch_Click"
                                    Tag="cyan"/>
                        </StackPanel>

                        <!-- ===== THROTTLE ===== -->
                        <StackPanel x:Name="ThrottlePedalGroup">
                        <ctrl:SectionCard Title="THROTTLE · DIRECTION &amp; RANGE"
                                          Icon="{StaticResource IconPedals}"
                                          AccentBrush="{StaticResource GreenBrush}">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,8">
                                    <TextBlock Text="Reverse Direction" Style="{StaticResource SliderLabel}"/>
                                    <ctrl:OffOnToggle x:Name="ThrottleDirCheck" VerticalAlignment="Center" Click="ThrottleDirCheck_Click"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,4">
                                    <TextBlock Text="Range Start" Style="{StaticResource SliderLabel}"/>
                                    <Slider x:Name="ThrottleMinSlider" Style="{StaticResource SettingSlider}" Minimum="0" Maximum="100" TickFrequency="1" ValueChanged="ThrottleMinSlider_ValueChanged"/>
                                    <TextBlock x:Name="ThrottleMinValue" Style="{StaticResource SliderValue}" Text="0%"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,4">
                                    <TextBlock Text="Range End" Style="{StaticResource SliderLabel}"/>
                                    <Slider x:Name="ThrottleMaxSlider" Style="{StaticResource SettingSlider}" Minimum="0" Maximum="100" TickFrequency="1" ValueChanged="ThrottleMaxSlider_ValueChanged"/>
                                    <TextBlock x:Name="ThrottleMaxValue" Style="{StaticResource SliderValue}" Text="100%"/>
                                </StackPanel>
                            </StackPanel>
                        </ctrl:SectionCard>
                        <!-- Throttle Output Curve -->
                        <ctrl:SectionCard Title="THROTTLE OUTPUT CURVE"
                                          Subtitle="// map physical position to game input"
                                          Icon="{StaticResource IconCurve}"
                                          AccentBrush="{StaticResource GreenBrush}">
                            <StackPanel>
                                <ctrl:MozaCurveEditor x:Name="ThrottleCurveEditor" Height="240"
                                                      AccentBrush="{StaticResource GreenBrush}"/>
                                <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                    <Button Content="LINEAR" Margin="0,0,8,0" Click="ThrottleCurvePreset_Linear"/>
                                    <Button Content="S CURVE" Margin="0,0,8,0" Click="ThrottleCurvePreset_SCurve"/>
                                    <Button Content="EXPONENTIAL" Margin="0,0,8,0" Click="ThrottleCurvePreset_Exponential"/>
                                    <Button Content="PARABOLIC" Click="ThrottleCurvePreset_Parabolic"/>
                                </StackPanel>
                            </StackPanel>
                        </ctrl:SectionCard>

                        <!-- Data-store sliders, driven by ThrottleCurveEditor -->
                        <StackPanel Visibility="Collapsed">
                            <Slider x:Name="ThrottleY1Slider" Minimum="0" Maximum="100" TickFrequency="1" ValueChanged="ThrottleY1Slider_ValueChanged"/>
                            <TextBlock x:Name="ThrottleY1Value" Text="20"/>
                            <Slider x:Name="ThrottleY2Slider" Minimum="0" Maximum="100" TickFrequency="1" ValueChanged="ThrottleY2Slider_ValueChanged"/>
                            <TextBlock x:Name="ThrottleY2Value" Text="40"/>
                            <Slider x:Name="ThrottleY3Slider" Minimum="0" Maximum="100" TickFrequency="1" ValueChanged="ThrottleY3Slider_ValueChanged"/>
                            <TextBlock x:Name="ThrottleY3Value" Text="60"/>
                            <Slider x:Name="ThrottleY4Slider" Minimum="0" Maximum="100" TickFrequency="1" ValueChanged="ThrottleY4Slider_ValueChanged"/>
                            <TextBlock x:Name="ThrottleY4Value" Text="80"/>
                            <Slider x:Name="ThrottleY5Slider" Minimum="0" Maximum="100" TickFrequency="1" ValueChanged="ThrottleY5Slider_ValueChanged"/>
                            <TextBlock x:Name="ThrottleY5Value" Text="100"/>
                        </StackPanel>
                        <ctrl:SectionCard Title="THROTTLE · CALIBRATION"
                                          Icon="{StaticResource IconCal}"
                                          AccentBrush="{StaticResource GreenBrush}">
                            <StackPanel Orientation="Horizontal" Margin="0,4">
                                <Button x:Name="ThrottleCalStartButton" Content="START CALIBRATION" Margin="0,0,10,0" Click="ThrottleCalStartButton_Click"/>
                                <Button x:Name="ThrottleCalStopButton" Content="STOP" Click="ThrottleCalStopButton_Click"/>
                            </StackPanel>
                        </ctrl:SectionCard>

                        </StackPanel>

                        <!-- ===== BRAKE ===== -->
                        <StackPanel x:Name="BrakePedalGroup" Visibility="Collapsed">
                        <ctrl:SectionCard Title="BRAKE · DIRECTION &amp; RANGE"
                                          Icon="{StaticResource IconPedals}"
                                          AccentBrush="{StaticResource RedBrush}">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,8">
                                    <TextBlock Text="Reverse Direction" Style="{StaticResource SliderLabel}"/>
                                    <ctrl:OffOnToggle x:Name="BrakeDirCheck" VerticalAlignment="Center" Click="BrakeDirCheck_Click"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,4">
                                    <TextBlock Text="Range Start" Style="{StaticResource SliderLabel}"/>
                                    <Slider x:Name="BrakeMinSlider" Style="{StaticResource SettingSlider}" Minimum="0" Maximum="100" TickFrequency="1" ValueChanged="BrakeMinSlider_ValueChanged"/>
                                    <TextBlock x:Name="BrakeMinValue" Style="{StaticResource SliderValue}" Text="0%"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,4">
                                    <TextBlock Text="Range End" Style="{StaticResource SliderLabel}"/>
                                    <Slider x:Name="BrakeMaxSlider" Style="{StaticResource SettingSlider}" Minimum="0" Maximum="100" TickFrequency="1" ValueChanged="BrakeMaxSlider_ValueChanged"/>
                                    <TextBlock x:Name="BrakeMaxValue" Style="{StaticResource SliderValue}" Text="100%"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,4">
                                    <TextBlock Text="Sensor Ratio" Style="{StaticResource SliderLabel}"/>
                                    <Slider x:Name="BrakeAngleRatioSlider" Style="{StaticResource SettingSlider}" Minimum="0" Maximum="100" TickFrequency="1" ValueChanged="BrakeAngleRatioSlider_ValueChanged"/>
                                    <TextBlock x:Name="BrakeAngleRatioValue" Style="{StaticResource SliderValue}" Text="50%"/>
                                </StackPanel>
                                <TextBlock Text="0% = Angle Sensor · 100% = Load Cell" Style="{StaticResource MutedHintText}" Margin="0,0,0,4"/>
                            </StackPanel>
                        </ctrl:SectionCard>
                        <!-- Brake Output Curve -->
                        <ctrl:SectionCard Title="BRAKE OUTPUT CURVE"
                                          Subtitle="// shape the brake response"
                                          Icon="{StaticResource IconCurve}"
                                          AccentBrush="{StaticResource RedBrush}">
                            <StackPanel>
                                <ctrl:MozaCurveEditor x:Name="BrakeCurveEditor" Height="240"
                                                      AccentBrush="{StaticResource RedBrush}"/>
                                <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                    <Button Content="LINEAR" Margin="0,0,8,0" Click="BrakeCurvePreset_Linear"/>
                                    <Button Content="S CURVE" Margin="0,0,8,0" Click="BrakeCurvePreset_SCurve"/>
                                    <Button Content="EXPONENTIAL" Margin="0,0,8,0" Click="BrakeCurvePreset_Exponential"/>
                                    <Button Content="PARABOLIC" Click="BrakeCurvePreset_Parabolic"/>
                                </StackPanel>
                            </StackPanel>
                        </ctrl:SectionCard>

                        <!-- Data-store sliders, driven by BrakeCurveEditor -->
                        <StackPanel Visibility="Collapsed">
                            <Slider x:Name="BrakeY1Slider" Minimum="0" Maximum="100" TickFrequency="1" ValueChanged="BrakeY1Slider_ValueChanged"/>
                            <TextBlock x:Name="BrakeY1Value" Text="20"/>
                            <Slider x:Name="BrakeY2Slider" Minimum="0" Maximum="100" TickFrequency="1" ValueChanged="BrakeY2Slider_ValueChanged"/>
                            <TextBlock x:Name="BrakeY2Value" Text="40"/>
                            <Slider x:Name="BrakeY3Slider" Minimum="0" Maximum="100" TickFrequency="1" ValueChanged="BrakeY3Slider_ValueChanged"/>
                            <TextBlock x:Name="BrakeY3Value" Text="60"/>
                            <Slider x:Name="BrakeY4Slider" Minimum="0" Maximum="100" TickFrequency="1" ValueChanged="BrakeY4Slider_ValueChanged"/>
                            <TextBlock x:Name="BrakeY4Value" Text="80"/>
                            <Slider x:Name="BrakeY5Slider" Minimum="0" Maximum="100" TickFrequency="1" ValueChanged="BrakeY5Slider_ValueChanged"/>
                            <TextBlock x:Name="BrakeY5Value" Text="100"/>
                        </StackPanel>
                        <ctrl:SectionCard Title="BRAKE · CALIBRATION"
                                          Icon="{StaticResource IconCal}"
                                          AccentBrush="{StaticResource RedBrush}">
                            <StackPanel Orientation="Horizontal" Margin="0,4">
                                <Button x:Name="BrakeCalStartButton" Content="START CALIBRATION" Margin="0,0,10,0" Click="BrakeCalStartButton_Click"/>
                                <Button x:Name="BrakeCalStopButton" Content="STOP" Click="BrakeCalStopButton_Click"/>
                            </StackPanel>
                        </ctrl:SectionCard>

                        </StackPanel>

                        <!-- ===== CLUTCH ===== -->
                        <StackPanel x:Name="ClutchPedalGroup" Visibility="Collapsed">
                        <ctrl:SectionCard Title="CLUTCH · DIRECTION &amp; RANGE"
                                          Icon="{StaticResource IconPedals}"
                                          AccentBrush="{StaticResource CyanBrush}">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,8">
                                    <TextBlock Text="Reverse Direction" Style="{StaticResource SliderLabel}"/>
                                    <ctrl:OffOnToggle x:Name="ClutchDirCheck" VerticalAlignment="Center" Click="ClutchDirCheck_Click"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,4">
                                    <TextBlock Text="Range Start" Style="{StaticResource SliderLabel}"/>
                                    <Slider x:Name="ClutchMinSlider" Style="{StaticResource SettingSlider}" Minimum="0" Maximum="100" TickFrequency="1" ValueChanged="ClutchMinSlider_ValueChanged"/>
                                    <TextBlock x:Name="ClutchMinValue" Style="{StaticResource SliderValue}" Text="0%"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,4">
                                    <TextBlock Text="Range End" Style="{StaticResource SliderLabel}"/>
                                    <Slider x:Name="ClutchMaxSlider" Style="{StaticResource SettingSlider}" Minimum="0" Maximum="100" TickFrequency="1" ValueChanged="ClutchMaxSlider_ValueChanged"/>
                                    <TextBlock x:Name="ClutchMaxValue" Style="{StaticResource SliderValue}" Text="100%"/>
                                </StackPanel>
                            </StackPanel>
                        </ctrl:SectionCard>
                        <!-- Clutch Output Curve -->
                        <ctrl:SectionCard Title="CLUTCH OUTPUT CURVE"
                                          Subtitle="// shape the clutch response"
                                          Icon="{StaticResource IconCurve}"
                                          AccentBrush="{StaticResource CyanBrush}">
                            <StackPanel>
                                <ctrl:MozaCurveEditor x:Name="ClutchCurveEditor" Height="240"
                                                      AccentBrush="{StaticResource CyanBrush}"/>
                                <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                    <Button Content="LINEAR" Margin="0,0,8,0" Click="ClutchCurvePreset_Linear"/>
                                    <Button Content="S CURVE" Margin="0,0,8,0" Click="ClutchCurvePreset_SCurve"/>
                                    <Button Content="EXPONENTIAL" Margin="0,0,8,0" Click="ClutchCurvePreset_Exponential"/>
                                    <Button Content="PARABOLIC" Click="ClutchCurvePreset_Parabolic"/>
                                </StackPanel>
                            </StackPanel>
                        </ctrl:SectionCard>

                        <!-- Data-store sliders, driven by ClutchCurveEditor -->
                        <StackPanel Visibility="Collapsed">
                            <Slider x:Name="ClutchY1Slider" Minimum="0" Maximum="100" TickFrequency="1" ValueChanged="ClutchY1Slider_ValueChanged"/>
                            <TextBlock x:Name="ClutchY1Value" Text="20"/>
                            <Slider x:Name="ClutchY2Slider" Minimum="0" Maximum="100" TickFrequency="1" ValueChanged="ClutchY2Slider_ValueChanged"/>
                            <TextBlock x:Name="ClutchY2Value" Text="40"/>
                            <Slider x:Name="ClutchY3Slider" Minimum="0" Maximum="100" TickFrequency="1" ValueChanged="ClutchY3Slider_ValueChanged"/>
                            <TextBlock x:Name="ClutchY3Value" Text="60"/>
                            <Slider x:Name="ClutchY4Slider" Minimum="0" Maximum="100" TickFrequency="1" ValueChanged="ClutchY4Slider_ValueChanged"/>
                            <TextBlock x:Name="ClutchY4Value" Text="80"/>
                            <Slider x:Name="ClutchY5Slider" Minimum="0" Maximum="100" TickFrequency="1" ValueChanged="ClutchY5Slider_ValueChanged"/>
                            <TextBlock x:Name="ClutchY5Value" Text="100"/>
                        </StackPanel>
                        <ctrl:SectionCard Title="CLUTCH · CALIBRATION"
                                          Icon="{StaticResource IconCal}"
                                          AccentBrush="{StaticResource CyanBrush}">
                            <StackPanel Orientation="Horizontal" Margin="0,4">
                                <Button x:Name="ClutchCalStartButton" Content="START CALIBRATION" Margin="0,0,10,0" Click="ClutchCalStartButton_Click"/>
                                <Button x:Name="ClutchCalStopButton" Content="STOP" Click="ClutchCalStopButton_Click"/>
                            </StackPanel>
                        </ctrl:SectionCard>
                        </StackPanel><!-- /ClutchPedalGroup -->

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ==================== AB9 SHIFTER TAB ==================== -->
            <TabItem x:Name="Ab9Tab" Header="AB9 Shifter" Visibility="Collapsed">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="22,18,22,40">
                    <StackPanel>

                        <!-- Status header -->
                        <Border Background="{StaticResource BgCardBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1" CornerRadius="8"
                                Padding="18,14" Margin="0,0,0,14">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse x:Name="Ab9StatusDot" Width="10" Height="10" Fill="Gray"
                                         VerticalAlignment="Center" Margin="0,0,12,0"/>
                                <TextBlock Text="AB9 ACTIVE SHIFTER" FontWeight="SemiBold" FontSize="13"
                                           VerticalAlignment="Center" Margin="0,0,18,0"/>
                                <TextBlock x:Name="Ab9StatusLabel" Text="Searching for AB9..."
                                           Style="{StaticResource MutedHintText}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <ctrl:SectionCard Title="MECHANICAL LAYOUT" Icon="{StaticResource IconShift}">
                            <StackPanel Orientation="Horizontal" Margin="0,4">
                                <TextBlock Text="Mode" Style="{StaticResource SliderLabel}"/>
                                <ComboBox x:Name="Ab9ModeCombo" Width="220" SelectionChanged="Ab9ModeCombo_Changed">
                                    <ComboBoxItem Content="5+R Layout 1" Tag="0"/>
                                    <ComboBoxItem Content="6+R Layout 1" Tag="4"/>
                                    <ComboBoxItem Content="6+R Layout 2" Tag="5"/>
                                    <ComboBoxItem Content="7+R Layout 1" Tag="6"/>
                                    <ComboBoxItem Content="7+R Layout 2" Tag="7"/>
                                    <ComboBoxItem Content="Sequential"   Tag="9"/>
                                </ComboBox>
                            </StackPanel>
                        </ctrl:SectionCard>

                        <ctrl:SectionCard Title="FEEL"
                                          Subtitle="// per-axis mechanical character"
                                          Icon="{StaticResource IconDamper}">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,4">
                                    <TextBlock Text="Mechanical Resistance" Style="{StaticResource SliderLabel}"/>
                                    <Slider x:Name="Ab9MechResistanceSlider" Style="{StaticResource SettingSlider}" Minimum="0" Maximum="100" TickFrequency="1" ValueChanged="Ab9MechResistanceSlider_ValueChanged"/>
                                    <TextBlock x:Name="Ab9MechResistanceValue" Style="{StaticResource SliderValue}" Text="50"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,4">
                                    <TextBlock Text="Spring" Style="{StaticResource SliderLabel}"/>
                                    <Slider x:Name="Ab9SpringSlider" Style="{StaticResource SettingSlider}" Minimum="0" Maximum="100" TickFrequency="1" ValueChanged="Ab9SpringSlider_ValueChanged"/>
                                    <TextBlock x:Name="Ab9SpringValue" Style="{StaticResource SliderValue}" Text="50"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,4">
                                    <TextBlock Text="Natural Damping" Style="{StaticResource SliderLabel}"/>
                                    <Slider x:Name="Ab9DampingSlider" Style="{StaticResource SettingSlider}" Minimum="0" Maximum="100" TickFrequency="1" ValueChanged="Ab9DampingSlider_ValueChanged"/>
                                    <TextBlock x:Name="Ab9DampingValue" Style="{StaticResource SliderValue}" Text="50"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,4">
                                    <TextBlock Text="Natural Friction" Style="{StaticResource SliderLabel}"/>
                                    <Slider x:Name="Ab9FrictionSlider" Style="{StaticResource SettingSlider}" Minimum="0" Maximum="100" TickFrequency="1" ValueChanged="Ab9FrictionSlider_ValueChanged"/>
                                    <TextBlock x:Name="Ab9FrictionValue" Style="{StaticResource SliderValue}" Text="50"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,4">
                                    <TextBlock Text="Max Output Torque Limit" Style="{StaticResource SliderLabel}"/>
                                    <Slider x:Name="Ab9MaxTorqueSlider" Style="{StaticResource SettingSlider}" Minimum="0" Maximum="100" TickFrequency="1" ValueChanged="Ab9MaxTorqueSlider_ValueChanged"/>
                                    <TextBlock x:Name="Ab9MaxTorqueValue" Style="{StaticResource SliderValue}" Text="50"/>
                                </StackPanel>
                            </StackPanel>
                        </ctrl:SectionCard>

                        <ctrl:SectionCard Title="ENGINE VIBRATION"
                                          Subtitle="// host-rendered rumble from RPM"
                                          Icon="{StaticResource IconBolt}">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,4">
                                    <TextBlock Text="Intensity" Style="{StaticResource SliderLabel}"/>
                                    <Slider x:Name="Ab9EngineVibIntensitySlider" Style="{StaticResource SettingSlider}" Minimum="0" Maximum="100" TickFrequency="1" ValueChanged="Ab9EngineVibIntensitySlider_ValueChanged"/>
                                    <TextBlock x:Name="Ab9EngineVibIntensityValue" Style="{StaticResource SliderValue}" Text="0"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,4">
                                    <TextBlock Text="Frequency" Style="{StaticResource SliderLabel}"/>
                                    <Slider x:Name="Ab9EngineVibFreqSlider" Style="{StaticResource SettingSlider}" Minimum="0" Maximum="200" TickFrequency="10" ValueChanged="Ab9EngineVibFreqSlider_ValueChanged"/>
                                    <TextBlock x:Name="Ab9EngineVibFreqValue" Style="{StaticResource SliderValue}" Text="100 Hz"/>
                                </StackPanel>
                            </StackPanel>
                        </ctrl:SectionCard>

                        <ctrl:SectionCard Title="GEAR SHIFT" Icon="{StaticResource IconShift}">
                            <StackPanel Orientation="Horizontal" Margin="0,4">
                                <TextBlock Text="Vibration Intensity" Style="{StaticResource SliderLabel}"/>
                                <Slider x:Name="Ab9GearShiftVibSlider" Style="{StaticResource SettingSlider}" Minimum="0" Maximum="100" TickFrequency="1" ValueChanged="Ab9GearShiftVibSlider_ValueChanged"/>
                                <TextBlock x:Name="Ab9GearShiftVibValue" Style="{StaticResource SliderValue}" Text="0"/>
                            </StackPanel>
                        </ctrl:SectionCard>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ==================== mBOOSTER TAB ==================== -->
            <TabItem x:Name="MBoosterTab" Header="mBooster" Visibility="Collapsed">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="22,18,22,40">
                    <StackPanel>

                        <ctrl:SectionCard Title="MBOOSTER PEDALS"
                                          Subtitle="// host-rendered effects · per-device role + position"
                                          Icon="{StaticResource IconPedals}">
                            <StackPanel>
                                <TextBlock TextWrapping="Wrap" Style="{StaticResource MutedHintText}" Margin="0,0,0,12">
                                    Each connected mBooster appears below. Pick a role (Throttle/Brake/Clutch) per device to route its
                                    pedal position. Effects are host-rendered per the documented protocol — enable each effect you want
                                    to feel and adjust its intensity. The Calibration section is experimental and may not be honored by
                                    mBooster firmware.
                                </TextBlock>
                                <StackPanel Orientation="Horizontal" Margin="0,4">
                                    <TextBlock Text="Device" Style="{StaticResource SliderLabel}"/>
                                    <ComboBox x:Name="MBoosterDeviceCombo" Width="320" SelectionChanged="MBoosterDeviceCombo_Changed"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,8">
                                    <Ellipse x:Name="MBoosterStatusDot" Width="10" Height="10" Fill="Gray"
                                             VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <TextBlock x:Name="MBoosterStatusLabel" Text="No mBooster connected"
                                               Style="{StaticResource MutedHintText}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </StackPanel>
                        </ctrl:SectionCard>

                        <!-- Per-device panel: wraps Role/Position + Effects + Calibration into nested cards -->
                        <StackPanel x:Name="MBoosterDevicePanel" Visibility="Collapsed">

                            <ctrl:SectionCard Title="PEDAL ROLE" Icon="{StaticResource IconPedals}">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,4">
                                        <TextBlock Text="Role" Style="{StaticResource SliderLabel}"/>
                                        <ComboBox x:Name="MBoosterRoleCombo" Width="160" SelectionChanged="MBoosterRoleCombo_Changed">
                                            <ComboBoxItem Content="Disabled"  Tag="0"/>
                                            <ComboBoxItem Content="Throttle"  Tag="1"/>
                                            <ComboBoxItem Content="Brake"     Tag="2"/>
                                            <ComboBoxItem Content="Clutch"    Tag="3"/>
                                        </ComboBox>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,4">
                                        <TextBlock Text="Position" Style="{StaticResource SliderLabel}"/>
                                        <ProgressBar x:Name="MBoosterPositionBar" Width="220" Height="14" Minimum="0" Maximum="100" Value="0"/>
                                        <TextBlock x:Name="MBoosterPositionLabel" Style="{StaticResource SliderValue}" Text="0 %"/>
                                    </StackPanel>
                                </StackPanel>
                            </ctrl:SectionCard>

                            <ctrl:SectionCard Title="EFFECTS"
                                              Subtitle="// triggers: ABS on game signal · Lockup on brake&gt;0.8 · Threshold on edge · Engine continuous"
                                              Icon="{StaticResource IconBolt}">
                                <StackPanel>

                            <Expander Header="ABS" IsExpanded="True">
                                <StackPanel Margin="8,4">
                                    <StackPanel Orientation="Horizontal" Margin="0,4">
                                        <ctrl:OffOnToggle x:Name="MBoosterAbsEnable" Content="Enable" VerticalAlignment="Center" Width="120" Checked="MBoosterAbsEnable_Changed" Unchecked="MBoosterAbsEnable_Changed"/>
                                        <Slider x:Name="MBoosterAbsIntensity" Style="{StaticResource SettingSlider}" Minimum="0" Maximum="100" TickFrequency="1" ValueChanged="MBoosterAbsIntensity_ValueChanged"/>
                                        <TextBlock x:Name="MBoosterAbsIntensityValue" Style="{StaticResource SliderValue}" Text="50"/>
                                        <Button x:Name="MBoosterAbsTest" Content="Test 1s" Margin="6,0,0,0" Padding="10,2" Click="MBoosterAbsTest_Click"/>
                                    </StackPanel>
                                </StackPanel>
                            </Expander>
                            <Expander Header="Lockup" IsExpanded="True">
                                <StackPanel Margin="8,4">
                                    <StackPanel Orientation="Horizontal" Margin="0,4">
                                        <ctrl:OffOnToggle x:Name="MBoosterLockupEnable" Content="Enable" VerticalAlignment="Center" Width="120" Checked="MBoosterLockupEnable_Changed" Unchecked="MBoosterLockupEnable_Changed"/>
                                        <Slider x:Name="MBoosterLockupIntensity" Style="{StaticResource SettingSlider}" Minimum="0" Maximum="100" TickFrequency="1" ValueChanged="MBoosterLockupIntensity_ValueChanged"/>
                                        <TextBlock x:Name="MBoosterLockupIntensityValue" Style="{StaticResource SliderValue}" Text="50"/>
                                        <Button x:Name="MBoosterLockupTest" Content="Test 1s" Margin="6,0,0,0" Padding="10,2" Click="MBoosterLockupTest_Click"/>
                                    </StackPanel>
                                </StackPanel>
                            </Expander>
                            <Expander Header="Threshold" IsExpanded="True">
                                <StackPanel Margin="8,4">
                                    <StackPanel Orientation="Horizontal" Margin="0,4">
                                        <ctrl:OffOnToggle x:Name="MBoosterThresholdEnable" Content="Enable" VerticalAlignment="Center" Width="120" Checked="MBoosterThresholdEnable_Changed" Unchecked="MBoosterThresholdEnable_Changed"/>
                                        <Slider x:Name="MBoosterThresholdIntensity" Style="{StaticResource SettingSlider}" Minimum="0" Maximum="100" TickFrequency="1" ValueChanged="MBoosterThresholdIntensity_ValueChanged"/>
                                        <TextBlock x:Name="MBoosterThresholdIntensityValue" Style="{StaticResource SliderValue}" Text="50"/>
                                        <Button x:Name="MBoosterThresholdTest" Content="Test 1s" Margin="6,0,0,0" Padding="10,2" Click="MBoosterThresholdTest_Click"/>
                                    </StackPanel>
                                </StackPanel>
                            </Expander>
                            <Expander Header="Engine (continuous — auto-clamped to 10%)" IsExpanded="False">
                                <StackPanel Margin="8,4">
                                    <StackPanel Orientation="Horizontal" Margin="0,4">
                                        <ctrl:OffOnToggle x:Name="MBoosterEngineEnable" Content="Enable" VerticalAlignment="Center" Width="120" Checked="MBoosterEngineEnable_Changed" Unchecked="MBoosterEngineEnable_Changed"/>
                                        <Slider x:Name="MBoosterEngineIntensity" Style="{StaticResource SettingSlider}" Minimum="0" Maximum="100" TickFrequency="1" ValueChanged="MBoosterEngineIntensity_ValueChanged"/>
                                        <TextBlock x:Name="MBoosterEngineIntensityValue" Style="{StaticResource SliderValue}" Text="50"/>
                                        <Button x:Name="MBoosterEngineTest" Content="Test 1s" Margin="6,0,0,0" Padding="10,2" Click="MBoosterEngineTest_Click"/>
                                    </StackPanel>
                                </StackPanel>
                            </Expander>

                                </StackPanel>
                            </ctrl:SectionCard>

                            <ctrl:SectionCard Title="CALIBRATION"
                                              Subtitle="// experimental — may not be honored by mBooster firmware"
                                              Icon="{StaticResource IconCal}"
                                              AccentBrush="{StaticResource AmberBrush}">
                                <StackPanel>
                                    <TextBlock TextWrapping="Wrap" Foreground="#FFE082" FontSize="11" Margin="0,0,0,8">
                                        The pedal-config command surface (direction / min / max / 5-point curve) is from the standard Moza pedal
                                        protocol. Whether mBooster firmware acknowledges these reads/writes is unverified — your changes may
                                        appear to take effect locally but be silently ignored by the device. Use "Read from device" to check
                                        whether values come back at all.
                                    </TextBlock>
                                    <StackPanel Orientation="Horizontal" Margin="0,4">
                                        <ctrl:OffOnToggle x:Name="MBoosterDirCheck" Content="Reversed direction" Checked="MBoosterDirCheck_Changed" Unchecked="MBoosterDirCheck_Changed"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,4">
                                        <TextBlock Text="Min (raw)" Style="{StaticResource SliderLabel}"/>
                                        <Slider x:Name="MBoosterMinSlider" Style="{StaticResource SettingSlider}" Minimum="0" Maximum="65535" TickFrequency="1024" ValueChanged="MBoosterMinSlider_ValueChanged"/>
                                        <TextBlock x:Name="MBoosterMinValue" Style="{StaticResource SliderValue}" Text="0"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,4">
                                        <TextBlock Text="Max (raw)" Style="{StaticResource SliderLabel}"/>
                                        <Slider x:Name="MBoosterMaxSlider" Style="{StaticResource SettingSlider}" Minimum="0" Maximum="65535" TickFrequency="1024" ValueChanged="MBoosterMaxSlider_ValueChanged"/>
                                        <TextBlock x:Name="MBoosterMaxValue" Style="{StaticResource SliderValue}" Text="0"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,8">
                                        <Button x:Name="MBoosterReadCalButton" Content="READ FROM DEVICE" Margin="0,0,6,0" Click="MBoosterReadCalButton_Click"/>
                                        <Button x:Name="MBoosterApplyCalButton" Content="APPLY" Click="MBoosterApplyCalButton_Click"/>
                                    </StackPanel>
                                </StackPanel>
                            </ctrl:SectionCard>

                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ==================== HUB TAB ==================== -->
            <TabItem x:Name="HubTab" Header="Hub" Visibility="Collapsed">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="22,18,22,40">
                    <StackPanel>

                        <ctrl:SectionCard Title="UNIVERSAL HUB · PEDALS"
                                          Subtitle="// pedals port (polled every 2 seconds)"
                                          Icon="{StaticResource IconPedals}">
                            <StackPanel Orientation="Horizontal" Margin="0,4">
                                <Ellipse x:Name="HubPedals1Dot" Width="10" Height="10" Fill="Gray"
                                         VerticalAlignment="Center" Margin="0,0,12,0"/>
                                <TextBlock Text="Pedals Port" Style="{StaticResource SliderLabel}"/>
                                <TextBlock x:Name="HubPedals1Label" Text="—"
                                           FontFamily="{StaticResource FontMono}"
                                           Foreground="{StaticResource TextDimBrush}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </ctrl:SectionCard>

                        <ctrl:SectionCard Title="ACCESSORIES" Icon="{StaticResource IconBolt}">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,4">
                                    <Ellipse x:Name="HubPort1Dot" Width="10" Height="10" Fill="Gray"
                                             VerticalAlignment="Center" Margin="0,0,12,0"/>
                                    <TextBlock Text="Port 1" Style="{StaticResource SliderLabel}"/>
                                    <TextBlock x:Name="HubPort1Label" Text="—"
                                               FontFamily="{StaticResource FontMono}"
                                               Foreground="{StaticResource TextDimBrush}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,4">
                                    <Ellipse x:Name="HubPort2Dot" Width="10" Height="10" Fill="Gray"
                                             VerticalAlignment="Center" Margin="0,0,12,0"/>
                                    <TextBlock Text="Port 2" Style="{StaticResource SliderLabel}"/>
                                    <TextBlock x:Name="HubPort2Label" Text="—"
                                               FontFamily="{StaticResource FontMono}"
                                               Foreground="{StaticResource TextDimBrush}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,4">
                                    <Ellipse x:Name="HubPort3Dot" Width="10" Height="10" Fill="Gray"
                                             VerticalAlignment="Center" Margin="0,0,12,0"/>
                                    <TextBlock Text="Port 3" Style="{StaticResource SliderLabel}"/>
                                    <TextBlock x:Name="HubPort3Label" Text="—"
                                               FontFamily="{StaticResource FontMono}"
                                               Foreground="{StaticResource TextDimBrush}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </StackPanel>
                        </ctrl:SectionCard>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ==================== OPTIONS TAB ==================== -->
            <TabItem Header="Options">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="22,18,22,40">
                    <StackPanel>

                        <ctrl:SectionCard Title="PROFILES" Icon="{StaticResource IconBolt}">
                            <StackPanel Orientation="Horizontal" Margin="0,8">
                                <TextBlock Text="Apply profile settings on launch" Style="{StaticResource SliderLabel}"/>
                                <ctrl:OffOnToggle x:Name="AutoApplyProfileCheck" VerticalAlignment="Center"
                                          Checked="AutoApplyProfileCheck_Changed" Unchecked="AutoApplyProfileCheck_Changed"/>
                            </StackPanel>
                        </ctrl:SectionCard>

                        <ctrl:SectionCard Title="WHEEL LED OUTPUT"
                                          Subtitle="// rpm + buttons throttling"
                                          Icon="{StaticResource IconLed}">
                            <StackPanel>
                                <TextBlock TextWrapping="Wrap" Style="{StaticResource MutedHintText}" Margin="0,0,0,8"
                                           Text="Recommended: leave LED options below OFF unless you experience LED issues."/>
                                <StackPanel Orientation="Horizontal" Margin="0,8">
                                    <TextBlock Text="Limit updates to wheel" Style="{StaticResource SliderLabel}"/>
                                    <ctrl:OffOnToggle x:Name="LimitWheelUpdatesCheck" VerticalAlignment="Center"
                                              Checked="LimitWheelUpdatesCheck_Changed" Unchecked="LimitWheelUpdatesCheck_Changed"/>
                                </StackPanel>
                                <TextBlock Text="Only send LED data when it actually changes."
                                           Style="{StaticResource MutedHintText}" Margin="0,4,0,0" TextWrapping="Wrap"/>
                                <StackPanel Orientation="Horizontal" Margin="0,8">
                                    <TextBlock Text="Always resend bitmask" Style="{StaticResource SliderLabel}"/>
                                    <ctrl:OffOnToggle x:Name="AlwaysResendBitmaskCheck" VerticalAlignment="Center"
                                              Checked="AlwaysResendBitmaskCheck_Changed" Unchecked="AlwaysResendBitmaskCheck_Changed"/>
                                </StackPanel>
                                <TextBlock Text="Always send the LED bitmask with color updates, even if unchanged. Causes extra traffic so do not use unless required."
                                           Style="{StaticResource MutedHintText}" Margin="0,4,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                        </ctrl:SectionCard>

                        <ctrl:SectionCard Title="USB DETECTION" Icon="{StaticResource IconRefresh}">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,8">
                                    <TextBlock Text="Disable serial-probe fallback (advanced)" Style="{StaticResource SliderLabel}"/>
                                    <ctrl:OffOnToggle x:Name="DisableSerialProbeFallbackCheck" VerticalAlignment="Center"
                                              Checked="DisableSerialProbeFallbackCheck_Changed" Unchecked="DisableSerialProbeFallbackCheck_Changed"/>
                                </StackPanel>
                                <TextBlock Text="Default behaviour: Moza devices are discovered via Windows USB enumeration. If that returns nothing (Wine/Proton without USB enumeration, driver missing) the plugin falls back to writing a Moza protocol probe to every COM port. Check this to forbid the probe entirely — guarantees no Moza writes to non-Moza serial devices, but Moza hardware won't be found on systems where the registry path is unavailable."
                                           Style="{StaticResource MutedHintText}" Margin="0,4,0,0" TextWrapping="Wrap"/>
                                <StackPanel Orientation="Horizontal" Margin="0,8">
                                    <TextBlock Text="Disable AB9 active-shifter detection" Style="{StaticResource SliderLabel}"/>
                                    <ctrl:OffOnToggle x:Name="DisableAb9DetectionCheck" VerticalAlignment="Center"
                                              Checked="DisableAb9DetectionCheck_Changed" Unchecked="DisableAb9DetectionCheck_Changed"/>
                                </StackPanel>
                                <TextBlock Text="Skip the AB9 reconnect probe. Auto-skipped already whenever the MOZA USB registry path returns empty (Wine/Proton), because the COM-port sweep that runs in that mode can lock up SimHub. Check this to skip the probe explicitly on any system. The wheelbase probe fallback is unaffected."
                                           Style="{StaticResource MutedHintText}" Margin="0,4,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                        </ctrl:SectionCard>

                        <ctrl:SectionCard Title="DASHBOARD TELEMETRY" Icon="{StaticResource IconDiag}">
                            <StackPanel>
                                <!-- Hidden: dashboard upload/download UI collapsed while the feature is
                                     in development. Runtime values are forced off in MozaPlugin; the
                                     upload/download scaffolding is intentionally preserved. -->
                                <StackPanel Visibility="Collapsed">
                                    <ctrl:OffOnToggle x:Name="UploadDashboardCheck" Content="Upload dashboard on connect"
                                              Margin="0,8,0,4" Checked="UploadDashboard_Changed" Unchecked="UploadDashboard_Changed"/>
                                    <ctrl:OffOnToggle x:Name="DownloadDashboardCheck" Content="Download dashboards from wheel"
                                              Margin="0,8,0,4" Checked="DownloadDashboard_Changed" Unchecked="DownloadDashboard_Changed"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                    <TextBlock Text="Wheel firmware era:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <ComboBox x:Name="FirmwareEraCombo" Width="500"
                                              SelectionChanged="FirmwareEra_Changed">
                                        <ComboBoxItem Content="Auto — Attempt to detect from wheel handshake"/>
                                        <ComboBoxItem Content="2024 era — (URL subscription)"/>
                                        <ComboBoxItem Content="2025 era — VGS"/>
                                        <ComboBoxItem Content="2026 era — CSP/KSP"/>
                                    </ComboBox>
                                </StackPanel>
                                <TextBlock TextWrapping="Wrap" Style="{StaticResource MutedHintText}" Margin="0,4,0,0"
                                           Text="Auto detects the wheel's firmware era from its handshake (catalog push and identity) and picks the matching wire protocol. Override only if telemetry stays broken — pick the era that matches your wheel hardware. Telemetry restarts automatically on change."/>
                            </StackPanel>
                        </ctrl:SectionCard>

                        <ctrl:SectionCard Title="RESET" Icon="{StaticResource IconAlert}">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,8">
                                    <Button x:Name="ClearAllSettingsButton" Content="CLEAR ALL SETTINGS &amp; PROFILES"
                                            Style="{StaticResource MozaButtonDanger}"
                                            Click="ClearAllSettingsButton_Click"/>
                                </StackPanel>
                                <TextBlock Text="This will reset all plugin settings and profiles to their defaults."
                                           Style="{StaticResource MutedHintText}" Margin="0,4,0,0"/>
                            </StackPanel>
                        </ctrl:SectionCard>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Upload + Wheel Files tabs were moved to the wheel device page
                 (Devices/MozaWheelSettingsControl.xaml — FilesTab). The
                 functionality is wheel-scoped, so it lives next to the rest
                 of the per-wheel settings rather than at the plugin level. -->
            <TabItem Header="Upload" Visibility="Collapsed">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="22,18,22,40">
                    <StackPanel>

                        <!-- Work-in-progress banner -->
                        <Border Style="{StaticResource BannerBorder}">
                            <StackPanel>
                                <TextBlock FontSize="14" FontWeight="Bold" Foreground="{StaticResource AmberBrush}"
                                           Text="⚠  Not working yet"/>
                                <TextBlock TextWrapping="Wrap" Foreground="#FFE082" FontSize="11" Margin="0,4,0,0"
                                           Text="Dashboard upload is in development and does NOT currently push files to the wheel. The UI here builds the upload bundle and starts the handshake, but the wheel doesn't engage the file-transfer state machine on our connect sequence, so the upload times out without writing anything. Nothing here is destructive — the button is safe to click, it just won't apply your dashboard. Use PitHouse for real uploads in the meantime."/>
                            </StackPanel>
                        </Border>

                        <ctrl:SectionCard Title="DASHBOARD UPLOAD"
                                          Subtitle="// push a .mzdash file to the connected wheel"
                                          Icon="{StaticResource IconDiag}">
                            <StackPanel>
                                <TextBlock TextWrapping="Wrap" Style="{StaticResource MutedHintText}" Margin="0,0,0,12"
                                           Text="Status reflects the latest wheel ack sub-msg (type=0x01 progress / type=0x11 complete) — bytes_written should rise toward total_size and end equal on a clean upload."/>
                                <TextBlock Text="SOURCE" Style="{StaticResource MutedHintText}" Margin="0,0,0,6"/>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <RadioButton x:Name="UploadSourceFileRadio" Content="Local .mzdash file"
                                                 GroupName="UploadSource" IsChecked="True"
                                                 Margin="0,0,16,0" VerticalAlignment="Center"
                                                 Foreground="{StaticResource TextBrush}"
                                                 Click="UploadSourceRadio_Click"/>
                                    <RadioButton x:Name="UploadSourceLibraryRadio" Content="Dashboard library"
                                                 GroupName="UploadSource"
                                                 VerticalAlignment="Center"
                                                 Foreground="{StaticResource TextBrush}"
                                                 Click="UploadSourceRadio_Click"/>
                                </StackPanel>
                                <StackPanel x:Name="UploadFilePanel" Orientation="Horizontal" Margin="0,0,0,8">
                                    <Button Content="PICK .MZDASH…" Margin="0,0,8,0" Click="UploadPickFile_Click"/>
                                    <TextBlock x:Name="UploadPickedFileText" VerticalAlignment="Center"
                                               Style="{StaticResource MutedHintText}"
                                               Text="(no file selected)" TextTrimming="CharacterEllipsis"
                                               MaxWidth="500"/>
                                </StackPanel>
                                <StackPanel x:Name="UploadLibraryPanel" Orientation="Horizontal" Margin="0,0,0,8"
                                            Visibility="Collapsed">
                                    <TextBlock Text="Dashboard:" VerticalAlignment="Center" Width="100"/>
                                    <ComboBox x:Name="UploadLibraryCombo" Width="280" Margin="0,0,8,0"
                                              SelectionChanged="UploadLibraryCombo_SelectionChanged"/>
                                    <Button Content="REFRESH" Click="UploadLibraryRefresh_Click"/>
                                </StackPanel>
                                <Separator Margin="0,8,0,12"/>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                    <Button x:Name="UploadNowButton" Content="UPLOAD NOW" MinWidth="120"
                                            Style="{StaticResource MozaButtonPrimary}"
                                            Click="UploadNow_Click"/>
                                    <TextBlock x:Name="UploadStatusText" VerticalAlignment="Center"
                                               Style="{StaticResource MutedHintText}" Margin="14,0,0,0"
                                               Text="idle"/>
                                </StackPanel>
                                <Grid Margin="0,0,0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="220"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Dashboard name:" Style="{StaticResource KvKeyText}" Margin="0,3"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" x:Name="UploadInfoNameText" Style="{StaticResource KvValueText}" Margin="0,3" Text="—"/>
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Raw size:" Style="{StaticResource KvKeyText}" Margin="0,3"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1" x:Name="UploadInfoRawSizeText" Style="{StaticResource KvValueText}" Margin="0,3" Text="—"/>
                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="MD5:" Style="{StaticResource KvKeyText}" Margin="0,3"/>
                                    <TextBlock Grid.Row="2" Grid.Column="1" x:Name="UploadInfoMd5Text" Style="{StaticResource KvValueText}" Margin="0,3" Text="—"/>
                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="In flight:" Style="{StaticResource KvKeyText}" Margin="0,3"/>
                                    <TextBlock Grid.Row="3" Grid.Column="1" x:Name="UploadInfoInFlightText" Style="{StaticResource KvValueText}" Margin="0,3" Text="—"/>
                                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Last ack bytes_written / total:" Style="{StaticResource KvKeyText}" Margin="0,3"/>
                                    <TextBlock Grid.Row="4" Grid.Column="1" x:Name="UploadInfoProgressText" Style="{StaticResource KvValueText}" Margin="0,3" Text="—"/>
                                    <TextBlock Grid.Row="5" Grid.Column="0" Text="Last ack status byte:" Style="{StaticResource KvKeyText}" Margin="0,3"/>
                                    <TextBlock Grid.Row="5" Grid.Column="1" x:Name="UploadInfoStatusByteText" Style="{StaticResource KvValueText}" Margin="0,3" Text="—"/>
                                </Grid>
                                <TextBlock TextWrapping="Wrap" Style="{StaticResource MutedHintText}" Margin="0,14,0,0"
                                           Text="Note: Uploads require the wheel to be connected and a management session negotiated. PNG resources referenced by widgets are not yet bundled — single-file mzdash uploads only (Gap 2 of the upload protocol implementation plan)."/>
                            </StackPanel>
                        </ctrl:SectionCard>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Wheel Files" Visibility="Collapsed">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="22,18,22,40">
                    <ctrl:SectionCard Title="WHEEL FILES"
                                      Subtitle="// dashboards the wheel reports via session 0x09 configJson"
                                      Icon="{StaticResource IconDiag}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <Button x:Name="WheelFilesRefreshButton" Content="REFRESH"
                                        Click="WheelFilesRefresh_Click" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                <TextBlock x:Name="WheelFilesStatusBox" VerticalAlignment="Center"
                                           Style="{StaticResource MutedHintText}" Text="—"/>
                            </StackPanel>
                            <TextBlock TextWrapping="Wrap" Style="{StaticResource MutedHintText}" Margin="0,0,0,10"
                                       Text="Delete is temporarily disabled — the completelyRemove RPC currently wedges firmware until the wheelbase is power-cycled. List refreshes after every upload + on connect."/>
                            <DataGrid x:Name="WheelFilesGrid" AutoGenerateColumns="False" IsReadOnly="True"
                                      CanUserAddRows="False" CanUserDeleteRows="False" CanUserResizeRows="False"
                                      SelectionMode="Single" HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                                      BorderThickness="1" RowHeight="24">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="State" Binding="{Binding State}" Width="80"/>
                                    <DataGridTextColumn Header="Title" Binding="{Binding Title}" Width="*"/>
                                    <DataGridTextColumn Header="DirName" Binding="{Binding DirName}" Width="200"/>
                                    <DataGridTextColumn Header="Hash" Binding="{Binding HashShort}" Width="120"/>
                                    <DataGridTextColumn Header="Last modified" Binding="{Binding LastModified}" Width="170"/>
                                    <DataGridTemplateColumn Header="" Width="80">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button Content="DELETE" Padding="8,2"
                                                        Click="WheelFilesDelete_Click"
                                                        Tag="{Binding}"
                                                        IsEnabled="False"
                                                        ToolTip="Disabled — completelyRemove RPC currently wedges wheel firmware until the wheelbase is power-cycled."/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </ctrl:SectionCard>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Diagnostics">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="22,18,22,40">
                    <StackPanel>

                        <!-- ============ Bandwidth ============ -->
                        <ctrl:SectionCard Title="BANDWIDTH"
                                          Subtitle="// serial throughput · 30-second window"
                                          Icon="{StaticResource IconDiag}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <!-- Inbound -->
                                <Border Grid.Column="0" Style="{StaticResource InnerCardBorder}"
                                        Margin="0,0,7,0">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                            <Ellipse Width="6" Height="6" Fill="{StaticResource CyanBrush}"
                                                     VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <TextBlock Text="INBOUND" FontSize="10" FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextDimBrush}"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <TextBlock x:Name="BandwidthInValueText" Text="0 B/s"
                                                   FontFamily="{StaticResource FontMono}" FontSize="24"
                                                   Foreground="{StaticResource CyanBrush}"
                                                   Margin="0,4,0,8"/>
                                        <!-- MaxValue = serial-port byte cap (115200 baud / 10 bits-per-byte) -->
                                        <ctrl:BandwidthSparkline x:Name="BandwidthInSparkline" Height="56"
                                                                 LineBrush="{StaticResource CyanBrush}"
                                                                 MaxValue="11520"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                            <TextBlock Text="PEAK" Style="{StaticResource KvKeyText}"/>
                                            <TextBlock x:Name="BandwidthInPeakText" Text="—" Style="{StaticResource KvValueText}"/>
                                            <TextBlock Text="SESSION" Style="{StaticResource KvKeyText}"/>
                                            <TextBlock x:Name="BandwidthInSessionText" Text="—" Style="{StaticResource KvValueText}"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                                <!-- Outbound -->
                                <Border Grid.Column="1" Style="{StaticResource InnerCardBorder}"
                                        Margin="7,0,0,0">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                            <Ellipse Width="6" Height="6" Fill="{StaticResource GreenBrush}"
                                                     VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <TextBlock Text="OUTBOUND" FontSize="10" FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextDimBrush}"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <TextBlock x:Name="BandwidthOutValueText" Text="0 B/s"
                                                   FontFamily="{StaticResource FontMono}" FontSize="24"
                                                   Foreground="{StaticResource GreenBrush}"
                                                   Margin="0,4,0,8"/>
                                        <ctrl:BandwidthSparkline x:Name="BandwidthOutSparkline" Height="56"
                                                                 LineBrush="{StaticResource GreenBrush}"
                                                                 MaxValue="11520"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                            <TextBlock Text="PEAK" Style="{StaticResource KvKeyText}"/>
                                            <TextBlock x:Name="BandwidthOutPeakText" Text="—" Style="{StaticResource KvValueText}"/>
                                            <TextBlock Text="SESSION" Style="{StaticResource KvKeyText}"/>
                                            <TextBlock x:Name="BandwidthOutSessionText" Text="—" Style="{StaticResource KvValueText}"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </ctrl:SectionCard>

                        <ctrl:SectionCard Title="SERIAL TRAFFIC CAPTURE"
                                          Subtitle="// records every TX/RX frame on wheelbase + AB9 pipes"
                                          Icon="{StaticResource IconDiag}">
                            <StackPanel>
                                <TextBlock TextWrapping="Wrap" Style="{StaticResource MutedHintText}" Margin="0,0,0,10"
                                           Text="Data lives in memory only — nothing is saved between SimHub launches. Click Stop to view the buffer; click Export to save a ZIP bundle (capture log + diagnostics dump + [Moza] log lines)."/>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                    <Button x:Name="SerialCaptureToggleButton" Content="START CAPTURE"
                                            Click="SerialCaptureToggle_Click" MinWidth="120"/>
                                    <TextBlock x:Name="SerialCaptureStatusText" Text="idle"
                                               Style="{StaticResource MutedHintText}" Margin="14,0,0,0"/>
                                </StackPanel>
                                <ctrl:OffOnToggle x:Name="StartCaptureOnNextLaunchCheck"
                                          Content="Start diagnostics capture on next launch/game switch"
                                          Click="StartCaptureOnNextLaunch_Click"
                                          Margin="0,0,0,10"
                                          ToolTip="Arms the capture so it begins immediately when the plugin re-initializes (next SimHub launch or plugin reload). Useful for catching connect/handshake traffic that's hard to arm in time manually."/>
                                <TextBox x:Name="SerialCaptureOutputBox" FontFamily="{StaticResource FontMono}" FontSize="11"
                                         IsReadOnly="True" TextWrapping="NoWrap" AcceptsReturn="True"
                                         Background="{StaticResource BgDeepBrush}"
                                         Foreground="{StaticResource TextDimBrush}"
                                         BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                         VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                                         Height="220" Margin="0,0,0,10" Padding="10" Visibility="Collapsed"/>
                                <StackPanel Orientation="Horizontal">
                                    <Button x:Name="SerialCaptureExportButton" Content="EXPORT BUNDLE (ZIP)…"
                                            Click="SerialCaptureExport_Click" IsEnabled="False"/>
                                    <Button x:Name="SerialCaptureCopyButton" Content="COPY CAPTURE TO CLIPBOARD"
                                            Click="SerialCaptureCopy_Click"
                                            Margin="8,0,0,0" IsEnabled="False"/>
                                </StackPanel>
                            </StackPanel>
                        </ctrl:SectionCard>

                        <!-- ============ Full Diagnostic Report (expandable) ============ -->
                        <ctrl:SectionCard Title="FULL DIAGNOSTIC REPORT"
                                          Subtitle="// same content as the Export bundle"
                                          Icon="{StaticResource IconDiag}">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <Button x:Name="FullDiagToggleButton" Content="EXPAND"
                                            Click="FullDiagToggle_Click" Margin="0,0,8,0"/>
                                    <Button Content="COPY ALL TO CLIPBOARD" Click="DiagCopyAll_Click"
                                            Margin="0,0,8,0"/>
                                    <TextBlock x:Name="FullDiagSummaryText"
                                               Style="{StaticResource MutedHintText}"
                                               VerticalAlignment="Center"
                                               Text="Click expand to render the full multi-section report."/>
                                </StackPanel>
                                <TextBox x:Name="FullDiagReportBox"
                                         FontFamily="{StaticResource FontMono}" FontSize="11"
                                         Foreground="{StaticResource TextDimBrush}"
                                         Background="{StaticResource BgDeepBrush}"
                                         BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                         IsReadOnly="True" TextWrapping="NoWrap"
                                         AcceptsReturn="True"
                                         VerticalScrollBarVisibility="Auto"
                                         HorizontalScrollBarVisibility="Auto"
                                         MaxHeight="400" Padding="10"
                                         Visibility="Collapsed"/>
                            </StackPanel>
                        </ctrl:SectionCard>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="CoAP">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="22,18,22,40">
                    <StackPanel>

                        <ctrl:SectionCard Title="COAP SERVER"
                                          Subtitle="// embedded CoAP/UDP server on loopback"
                                          Icon="{StaticResource IconBolt}">
                            <StackPanel>
                                <TextBlock TextWrapping="Wrap" Style="{StaticResource MutedHintText}" Margin="0,0,0,10"
                                           Text="When enabled, the plugin runs an embedded CoAP control server."/>
                                <StackPanel Orientation="Horizontal" Margin="0,8">
                                    <TextBlock Text="Enable CoAP server" Style="{StaticResource SliderLabel}"/>
                                    <ctrl:OffOnToggle x:Name="SdkEmulationEnabledCheck" VerticalAlignment="Center"
                                              Checked="SdkEmulationEnabledCheck_Changed" Unchecked="SdkEmulationEnabledCheck_Changed"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,8">
                                    <TextBlock Text="UDP port" Style="{StaticResource SliderLabel}"/>
                                    <TextBox x:Name="SdkCoapPortBox" Width="100" VerticalAlignment="Center"
                                             FontFamily="{StaticResource FontMono}"
                                             LostFocus="SdkCoapPortBox_LostFocus"
                                             KeyDown="SdkCoapPortBox_KeyDown"/>
                                    <TextBlock Text="(1024-65535, default 5683)"
                                               Style="{StaticResource MutedHintText}"
                                               VerticalAlignment="Center" Margin="10,0,0,0"/>
                                </StackPanel>
                            </StackPanel>
                        </ctrl:SectionCard>

                        <ctrl:SectionCard Title="STATUS" Icon="{StaticResource IconDiag}">
                            <StackPanel>
                                <Grid Margin="0,4,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="CoAP server" Style="{StaticResource LabelText}"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" x:Name="SdkServerStatusText"
                                               Text="Disabled"
                                               FontFamily="{StaticResource FontMono}"
                                               Foreground="{StaticResource TextDimBrush}"
                                               VerticalAlignment="Center"/>
                                </Grid>
                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                    <Button x:Name="SdkRefreshStatusButton" Content="REFRESH"
                                            Click="SdkRefreshStatusButton_Click" MinWidth="100"/>
                                </StackPanel>
                            </StackPanel>
                        </ctrl:SectionCard>

                        <ctrl:SectionCard Title="RECENT REQUESTS"
                                          Subtitle="// last 20 CoAP requests · live"
                                          Icon="{StaticResource IconDiag}">
                            <StackPanel>
                                <ListBox x:Name="SdkRecentRequestsList"
                                         FontFamily="{StaticResource FontMono}" FontSize="11"
                                         Background="{StaticResource BgDeepBrush}"
                                         Foreground="{StaticResource TextDimBrush}"
                                         BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                         Height="180"
                                         HorizontalContentAlignment="Stretch"/>
                            </StackPanel>
                        </ctrl:SectionCard>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

        </TabControl>
    </DockPanel>
</UserControl>
