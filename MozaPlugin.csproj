<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net48</TargetFramework>
    <PlatformTarget>x86</PlatformTarget>
    <OutputType>Library</OutputType>
    <RootNamespace>MozaPlugin</RootNamespace>
    <AssemblyName>MozaPlugin</AssemblyName>
    <LangVersion>latest</LangVersion>
    <Nullable>enable</Nullable>
    <AppendTargetFrameworkToOutputPath>false</AppendTargetFrameworkToOutputPath>
    <Version>0.0.0</Version>
    <AssemblyTitle>MozaPlugin</AssemblyTitle>
    <Description>SimHub plugin for MOZA Racing hardware</Description>
    <Product>MozaPlugin</Product>
    <Copyright>Copyright 2026</Copyright>
    <UseWPF>true</UseWPF>
    <ImportWindowsDesktopTargets>true</ImportWindowsDesktopTargets>
    <!-- Workaround for dotnet SDK 10.x CS0579 duplicate AssemblyAttribute when
         WPF's markup-compile temp project (`*_wpftmp.csproj`) re-imports the
         auto-generated obj/*.AssemblyInfo.cs. The temp project shares its obj
         dir with the parent and ends up compiling the generated assembly
         attributes twice. Disabling SDK auto-generation suppresses the
         duplicate; the version attributes are re-emitted by the
         WriteVersionInfo target below into a single shared VersionInfo.cs
         that both the main project and the wpftmp project pick up. See
         dotnet/wpf#93 and dotnet/sdk#7207. -->
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <GenerateTargetFrameworkAttribute>false</GenerateTargetFrameworkAttribute>
    <IncludePackageReferencesDuringMarkupCompilation>true</IncludePackageReferencesDuringMarkupCompilation>
    <!-- PitHouseStub is a sibling project nested inside this csproj's
         directory. The SDK's default `**\*.cs` Compile glob would otherwise
         sweep in PitHouseStub/Program.cs AND its auto-generated
         PitHouseStub/obj/.../PitHouseStub.AssemblyInfo.cs, which carries
         AssemblyVersion / AssemblyFileVersion / AssemblyInformationalVersion
         attributes that collide with the ones WriteVersionInfo emits below
         (CS0579). Excluding the whole subtree from default globs keeps the
         explicit `<EmbeddedResource Include="PitHouseStub\bin\...">` line
         intact while preventing the source files from being picked up
         twice. -->
    <DefaultItemExcludes>$(DefaultItemExcludes);PitHouseStub\**</DefaultItemExcludes>
    <!-- Force Platform=x86 so csproj-only builds (no sln) emit to bin\x86\<Config>\
         — matches the path sln-driven Release|x86 builds use, which the deploy
         scripts hard-code. Without this, `dotnet build MozaPlugin.csproj` defaults
         to Platform=AnyCPU and lands in bin\Release\, silently producing a stale
         deploy. Sln-level Release|x86 still wins because it sets Platform up front. -->
    <Platform Condition="'$(Platform)' == '' or '$(Platform)' == 'AnyCPU'">x86</Platform>
  </PropertyGroup>

  <ItemGroup>
    <Reference Include="SimHub.Plugins">
      <HintPath>libs\SimHub\SimHub.Plugins.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <Reference Include="GameReaderCommon">
      <HintPath>libs\SimHub\GameReaderCommon.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <Reference Include="SimHub.Logging">
      <HintPath>libs\SimHub\SimHub.Logging.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <Reference Include="SerialDash">
      <HintPath>libs\SimHub\SerialDash.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <Reference Include="BA63Driver">
      <HintPath>libs\SimHub\BA63Driver.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <Reference Include="HidSharp">
      <HintPath>libs\SimHub\HidSharp.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <Reference Include="System.IO.Compression" />
    <Reference Include="System.IO.Compression.FileSystem" />
    <Reference Include="System.Windows.Forms" />
  </ItemGroup>

  <ItemGroup>
    <EmbeddedResource Include="Data\Telemetry.json" LogicalName="MozaPlugin.Data.Telemetry.json" />
    <EmbeddedResource Include="DeviceTemplates\MozaWheelGeneric\MOZA Racing Wheel\device.json" LogicalName="MozaPlugin.Devices.WheelGeneric.device.json" />
    <EmbeddedResource Include="DeviceTemplates\MozaWheelOldProto\MOZA Old Protocol Wheel\device.json" LogicalName="MozaPlugin.Devices.WheelOldProto.device.json" />
    <EmbeddedResource Include="DeviceTemplates\MozaDashShdp\MOZA Dashboard\device.json" LogicalName="MozaPlugin.Devices.Dash.device.json" />
    <EmbeddedResource Include="DeviceTemplates\MozaWheelBase\MOZA Wheel Base\device.json" LogicalName="MozaPlugin.Devices.WheelBase.device.json" />
    <!-- Factory dashboards shipped with MOZA wheel firmware. Copied verbatim
         from PitHouse `bin/dashes/<Name>/<Name>.mzdash`. Name underscores in
         filenames map back to spaces in dashboard display name (e.g.
         `Rally_V1.mzdash` → "Rally V1"). LoadBuiltinProfiles uses the URL
         widget tree to derive per-widget tier-defs that match PitHouse's
         channel-renegotiation pattern when the wheel switches dashboards. -->
    <EmbeddedResource Include="Data\Dashes\*.mzdash">
      <LogicalName>MozaPlugin.Data.Dashes.%(Filename).mzdash</LogicalName>
    </EmbeddedResource>
  </ItemGroup>

  <!-- PitHouseStub project reference for build ordering only. The output is
       NOT linked into the plugin assembly; it's embedded as a manifest
       resource below so PitHouseStubManager can extract it at runtime.
       Path is relative to this csproj's directory (the repo root) — the
       PitHouseStub project sits in a sibling folder under that root, not
       above it. -->
  <ItemGroup>
    <ProjectReference Include="PitHouseStub\PitHouseStub.csproj">
      <ReferenceOutputAssembly>false</ReferenceOutputAssembly>
      <Private>false</Private>
      <SkipGetTargetFrameworkProperties>true</SkipGetTargetFrameworkProperties>
      <UndefineProperties>TargetFramework;Platform;PlatformTarget</UndefineProperties>
    </ProjectReference>
  </ItemGroup>

  <!-- Embed the built PitHouseStub exe as a manifest resource. We track
       $(Configuration) so Debug|x86 and Release|x86 builds each pick up the
       matching sibling output. The ProjectReference above guarantees the
       sibling builds before this target's GenerateResourceMain runs. -->
  <ItemGroup>
    <EmbeddedResource Include="PitHouseStub\bin\x86\$(Configuration)\MOZA Pit House.exe"
                      LogicalName="MozaPlugin.Sdk.PitHouseStub.exe"
                      Visible="false" />
  </ItemGroup>

  <!-- Sanity gate: fail fast with a clear message if the stub exe is missing
       when GenerateResourceMain goes to embed it. Without this, MSBuild
       would emit a confusing "file not found" deep inside the resource
       generation step. The ProjectReference above should ensure the sibling
       builds first; this target only fires if someone bypasses it (e.g.
       `dotnet build MozaPlugin.csproj` without restoring the sln). -->
  <Target Name="VerifyPitHouseStubBuilt" BeforeTargets="GenerateResourceMain">
    <Error Condition="!Exists('PitHouseStub\bin\x86\$(Configuration)\MOZA Pit House.exe')"
           Text="PitHouseStub output not found at 'PitHouseStub\bin\x86\$(Configuration)\MOZA Pit House.exe'. Build the sln (or run `dotnet build PitHouseStub/PitHouseStub.csproj -c $(Configuration)` first)." />
  </Target>

  <ItemGroup>
    <PackageReference Include="Microsoft.NETFramework.ReferenceAssemblies.net48" Version="1.0.3">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers</IncludeAssets>
    </PackageReference>
    <PackageReference Include="Newtonsoft.Json" Version="13.0.3">
      <Private>false</Private>
    </PackageReference>
    <PackageReference Include="log4net" Version="2.0.15">
      <Private>false</Private>
    </PackageReference>
  </ItemGroup>

  <!-- Copy output DLL to SimHub folder on build -->
  <Target Name="CopyToSimHub" AfterTargets="Build" Condition="'$(SIMHUB_PATH)' != ''">
    <Copy SourceFiles="$(OutputPath)$(AssemblyName).dll" DestinationFolder="$(SIMHUB_PATH)" />
  </Target>

  <!-- Re-emit the three version attributes ourselves since GenerateAssemblyInfo
       is off (see workaround comment above). The CI workflows pass /p:Version=...
       to stamp the build; without this target the value would never reach the
       DLL and DiagnosticsTextBuilder.GetPluginVersion() would fall back to the
       default 1.0.0.0. AssemblyVersion / AssemblyFileVersion require strict
       4-part numeric form, so we strip any SemVer prerelease/build suffix and
       pad to 4 parts. The full $(Version) (including suffix) goes into
       AssemblyInformationalVersion, which is what diagnostics displays. -->
  <Target Name="WriteVersionInfo" BeforeTargets="CoreCompile">
    <PropertyGroup>
      <_VersionNumeric>$(Version)</_VersionNumeric>
      <_VersionNumeric Condition="$(_VersionNumeric.Contains('-'))">$(_VersionNumeric.Substring(0, $(_VersionNumeric.IndexOf('-'))))</_VersionNumeric>
      <_VersionNumeric Condition="$(_VersionNumeric.Contains('+'))">$(_VersionNumeric.Substring(0, $(_VersionNumeric.IndexOf('+'))))</_VersionNumeric>
      <_VersionDotCount>$([MSBuild]::Subtract($(_VersionNumeric.Length), $(_VersionNumeric.Replace('.', '').Length)))</_VersionDotCount>
      <_VersionNumeric Condition="'$(_VersionDotCount)' == '0'">$(_VersionNumeric).0.0.0</_VersionNumeric>
      <_VersionNumeric Condition="'$(_VersionDotCount)' == '1'">$(_VersionNumeric).0.0</_VersionNumeric>
      <_VersionNumeric Condition="'$(_VersionDotCount)' == '2'">$(_VersionNumeric).0</_VersionNumeric>
    </PropertyGroup>
    <ItemGroup>
      <_PluginVersionAttr Include="System.Reflection.AssemblyVersionAttribute">
        <_Parameter1>$(_VersionNumeric)</_Parameter1>
      </_PluginVersionAttr>
      <_PluginVersionAttr Include="System.Reflection.AssemblyFileVersionAttribute">
        <_Parameter1>$(_VersionNumeric)</_Parameter1>
      </_PluginVersionAttr>
      <_PluginVersionAttr Include="System.Reflection.AssemblyInformationalVersionAttribute">
        <_Parameter1>$(Version)</_Parameter1>
      </_PluginVersionAttr>
    </ItemGroup>
    <WriteCodeFragment
        AssemblyAttributes="@(_PluginVersionAttr)"
        Language="C#"
        OutputDirectory="$(IntermediateOutputPath)"
        OutputFile="VersionInfo.cs">
      <Output TaskParameter="OutputFile" ItemName="Compile" />
      <Output TaskParameter="OutputFile" ItemName="FileWrites" />
    </WriteCodeFragment>
  </Target>

</Project>
